ulations of moose.", "access_right": "restricted", "creators": [{"name": "Hoffman, Justin D", "affiliation": null}, {"name": "Genoways, Hugh H", "affiliation": null}, {"name": "Choate, Jerry R", "affiliation": null}], "keywords": ["Biodiversity", "Mammalia", "Chiroptera", "Chordata", "Animalia", "bats", "bat"], "related_identifiers": [{"identifier": "hash://md5/7b0328f0b90c6d73a3f50d9a542b2d05", "relation": "hasVersion", "scheme": "url"}, {"identifier": "hash://sha256/202e59bbc7276b3ca00963cd059c0d9893333d3857ab61d5aef1db975cc05361", "relation": "hasVersion", "scheme": "url"}, {"identifier": "zotero://select/groups/5435545/items/9YSZEW4Z", "relation": "isDerivedFrom", "scheme": "url"}, {"identifier": "https://zotero.org/groups/5435545/items/9YSZEW4Z", "relation": "isDerivedFrom", "scheme": "url"}, {"identifier": "https://linker.bio/cut:hash://md5/9f3470ed73781a97d99db373f57bc1ac!/b148356-150813", "relation": "isDerivedFrom", "scheme": "url"}, {"identifier": "hash://md5/0157e8ec3f1f8eb877e7b6cd6fde26bc", "relation": "isPartOf", "scheme": "url"}, {"identifier": "10.5281/zenodo.1410543", "relation": "isCompiledBy", "resource_type": "software", "scheme": "doi"}], "custom": {"dwc:class": ["Mammalia"], "dwc:kingdom": ["Animalia"], "dwc:order": ["Chiroptera"], "dwc:phylum": ["Chordata"]}, "resource_type": {"title": "Journal article", "type": "publication", "subtype": "article"}, "journal": {"title": "ALCES VOL.", "volume": "42"}, "alternate_identifiers": [{"identifier": "hash://md5/7b0328f0b90c6d73a3f50d9a542b2d05"}, {"identifier": "urn:lsid:zotero.org:groups:5435545:items:9YSZEW4Z"}], "communities": [{"id": "batlit"}, {"id": "biosyslit"}], "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "19668484"}}]}}, "title": "LONG-DISTANCE DISPERSAL AND POPULATION TRENDS OF MOOSE IN THE CENTRAL UNITED STATES", "links": {"self": "https://zenodo.org/api/records/19668485", "self_html": "https://zenodo.org/records/19668485", "preview_ht