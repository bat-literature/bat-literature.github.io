            "itemType": "journalArticle",
            "title": "Pollinator effectiveness of native and non‐native flower visitors to an apparently generalist Andean shrub, Duranta mandonii (Verbenaceae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Stella",
                    "lastName": "Watts"
                },
                {
                    "creatorType": "author",
                    "firstName": "David Huamán",
