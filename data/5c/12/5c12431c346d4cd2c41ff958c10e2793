            "itemType": "journalArticle",
            "title": "Physiological Constraint to Food Ingestion in a New World Nectarivorous Bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nicte",
                    "lastName": "Ramírez P."
