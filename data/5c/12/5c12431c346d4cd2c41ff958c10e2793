        "data": {
            "key": "D7PV9WIY",
            "version": 58591,
            "itemType": "journalArticle",
            "title": "Lack of gene flow between the insular bat, Nyctalus azoreum and its mainland ancestor Nyctalus leisleri (Vespertilionidae, Chiroptera): evidence from microsatellites",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Patrícia",
                    "lastName": "Salgueiro"
                },
                {
                    "creatorType": "author",
