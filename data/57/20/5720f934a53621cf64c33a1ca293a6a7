            "itemType": "journalArticle",
            "title": "REVISION TAXONOMICA DE LOS MURCIELAGOS MAGUEYEROS DEL GENERO LEPTONYCTERIS (CHIROPTERA: PHYLLOSTOMIDAE)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Héctor T.",
