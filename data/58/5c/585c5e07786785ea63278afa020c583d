            "title": "Nectar-feeding bats and birds show parallel molecular adaptations in sugar metabolism enzymes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Joshua H.T.",
                    "lastName": "Potter"
                },
                {
                    "creatorType": "author",
