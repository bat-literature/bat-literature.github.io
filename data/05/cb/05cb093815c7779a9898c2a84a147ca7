            "itemType": "journalArticle",
            "title": "Diet and Cranial Morphology of Musonycteris harrisoni, a Highly Specialized Nectar-Feeding Bat in Western Mexico",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marco",
                    "lastName": "Tschapka"
                },
                {
                    "creatorType": "author",
