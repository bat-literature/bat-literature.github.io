            "title": "Molecular detection and epidemiology of astrovirus, bocavirus, and sapovirus in Italian children admitted to hospital with acute gastroenteritis, 2008–2009",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maria Cristina",
                    "lastName": "Medici"
                },
                {
                    "creatorType": "author",
