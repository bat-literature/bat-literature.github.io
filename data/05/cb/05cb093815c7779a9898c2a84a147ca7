            "itemType": "journalArticle",
            "title": "Inside or out? Cave size and landscape effects on cave-roosting bat assemblages in Brazilian Caatinga caves",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Juan Carlos",
