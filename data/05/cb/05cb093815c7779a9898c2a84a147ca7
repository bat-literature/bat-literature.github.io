            "itemType": "journalArticle",
            "title": "Ecological correlates of vulnerability to fragmentation among Afrotropical terrestrial small mammals in northeast Tanzania",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "William D.",
                    "lastName": "Newmark"
