        "data": {
            "key": "RS3FQJSW",
            "version": 84618,
            "itemType": "journalArticle",
            "title": "Dietary Variation in the Mexican Free-Tailed Bat (Tadarida brasiliensis mexicana)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "John O.",
                    "lastName": "Whitaker"
                },
                {
                    "creatorType": "author",
