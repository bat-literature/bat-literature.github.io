            "key": "RZQ2ZJE3",
            "version": 84699,
            "itemType": "journalArticle",
            "title": "Sublethal pathology in bats associated with stress and volcanic activity on Montserrat, West Indies",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Scott C.",
                    "lastName": "Pedersen"
                },
                {
                    "creatorType": "author",
                    "firstName": "Tracy E.",
