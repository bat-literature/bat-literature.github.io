        "data": {
            "key": "XA6KDCH7",
            "version": 84579,
            "itemType": "journalArticle",
            "title": "Hickmania Troglodytes, the Tasmanian Cave Spider, and its Potential Role in Cave Management",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "N E",
                    "lastName": "Doran"
                },
                {
                    "creatorType": "author",
