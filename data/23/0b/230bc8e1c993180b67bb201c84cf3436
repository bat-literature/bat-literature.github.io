            "itemType": "journalArticle",
            "title": "Viral and Host Attributes Underlying the Origins of Zoonotic Coronaviruses in Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alison E.",
                    "lastName": "Stout"
                },
