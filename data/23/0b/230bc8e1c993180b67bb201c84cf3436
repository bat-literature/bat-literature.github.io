            "title": "Use of systems biology to decipher host–pathogen interaction networks and predict biomarkers",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "A.",
                    "lastName": "Dix"
                },
                {
                    "creatorType": "author",
