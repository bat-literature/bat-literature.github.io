            "title": "Rapid flapping and fibre-reinforced membrane wings are key to high-performance bat flight",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marin",
                    "lastName": "Lauber"
                },
                {
                    "creatorType": "author",
                    "firstName": "Gabriel D.",
                    "lastName": "Weymouth"
