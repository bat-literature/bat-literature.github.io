            "itemType": "journalArticle",
            "title": "Evolutionary rescue: an emerging focus at the intersection between ecology and evolution.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Andrew",
                    "lastName": "Gonzalez"
                },
                {
