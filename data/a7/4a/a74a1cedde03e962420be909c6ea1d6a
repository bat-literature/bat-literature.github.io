            "title": "Double digest RADseq: An inexpensive method for de novo SNP discovery and genotyping in model and non-model species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Brant K.",
                    "lastName": "Peterson"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jesse N.",
                    "lastName": "Weber"
                },
                {
                    "creatorType": "author",
                    "firstName": "Emily H.",
