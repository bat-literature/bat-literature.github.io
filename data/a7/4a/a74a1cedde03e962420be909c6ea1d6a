            "title": "Fish viruses stored in RNAlater can remain infectious and even be temporarily protected from inactivation by heat or by tissue homogenates",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Phuc H.",
                    "lastName": "Pham"
                },
                {
                    "creatorType": "author",
                    "firstName": "Bibi S. H.",
                    "lastName": "Sokeechand"
                },
                {
                    "creatorType": "author",
