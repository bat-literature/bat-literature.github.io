            "title": "Candida albicans Hyr1p confers resistance to neutrophil killing and is a potential vaccine target.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Guanpingsheng",
                    "lastName": "Luo"
                },
                {
                    "creatorType": "author",
