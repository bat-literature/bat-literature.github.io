            "title": "Computational prediction of molecular pathogen-host interactions based on dual transcriptome data",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sylvie",
                    "lastName": "Schulze"
                },
                {
                    "creatorType": "author",
