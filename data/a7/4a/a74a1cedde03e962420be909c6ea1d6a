            "title": "DEBrowser: interactive differential expression analysis and visualization tool for count data",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alper",
                    "lastName": "Kucukural"
                },
                {
                    "creatorType": "author",
