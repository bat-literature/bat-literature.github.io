            "title": "An approach to the optimal allocation of conservation funds to minimize loss of genetic diversity between livestock breeds",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "H",
                    "lastName": "Simianer"
                },
                {
                    "creatorType": "author",
