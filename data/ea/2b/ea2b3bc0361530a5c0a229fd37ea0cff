        "data": {
            "key": "7YCIULZ6",
            "version": 55614,
            "itemType": "journalArticle",
            "title": "A relict tropical forest bat assemblage from the early Miocene of the Ribesalbes-Alcora Basin (Castelló, Spain)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Vicente D.",
                    "lastName": "Crespo"
                },
                {
                    "creatorType": "author",
                    "firstName": "Paloma",
