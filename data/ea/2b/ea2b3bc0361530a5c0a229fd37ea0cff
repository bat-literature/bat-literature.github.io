            "itemType": "journalArticle",
            "title": "Annual precipitation predicts the phylogenetic signal in bat–fruit interaction networks across the Neotropics",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Erick J.",
                    "lastName": "Corro"
                },
                {
                    "creatorType": "author",
                    "firstName": "Fabricio",
                    "lastName": "Villalobos"
                },
                {
                    "creatorType": "author",
                    "firstName": "Andrés",
