            "itemType": "journalArticle",
            "title": "Numbers of wildlife fatalities at renewable energy facilities in a targeted development region",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Tara J.",
                    "lastName": "Conkling"
                },
                {
                    "creatorType": "author",
                    "firstName": "Amy L.",
