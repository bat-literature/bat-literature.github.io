            "itemType": "journalArticle",
            "title": "Positively selected genes in the hoary bat (Lasiurus cinereus) lineage: prominence of thymus expression, immune and metabolic function, and regions of ancient synteny",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Robert S.",
                    "lastName": "Cornman"
                },
                {
                    "creatorType": "author",
                    "firstName": "Paul M.",
