            "itemType": "journalArticle",
            "title": "Bats from the classical site of Venta del Moro (Late Miocene, Eastern Spain)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Vicente D.",
                    "lastName": "Crespo"
                },
                {
                    "creatorType": "author",
