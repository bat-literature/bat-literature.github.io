            "itemType": "journalArticle",
            "title": "Are sacred caves still safe havens for the endemic bats of Madagascar?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Álvaro",
                    "lastName": "Fernández-Llamazares"
                },
