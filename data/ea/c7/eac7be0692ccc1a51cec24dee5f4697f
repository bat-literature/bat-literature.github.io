            "itemType": "journalArticle",
            "title": "A new species of bat (Chiroptera: Vespertilionidae) from the early Oligocene global cooling period, Brule Formation, North Dakota, USA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nicholas",
