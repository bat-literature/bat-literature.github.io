            "itemType": "journalArticle",
            "title": "Three New Early Middle Eocene Bats (Mammalia: Chiroptera) from Elderberry Canyon, Nevada, USA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nicholas J.",
                    "lastName": "Czaplewski"
                },
                {
