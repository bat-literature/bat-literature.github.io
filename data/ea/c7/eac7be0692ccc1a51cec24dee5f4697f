            "title": "The identity of Vespertilio oreias Temminck, 1840—solving a taxonomic puzzle",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Gábor",
                    "lastName": "Csorba"
                },
                {
                    "creatorType": "author",
