        "data": {
            "key": "J55R53T4",
            "version": 56017,
            "itemType": "journalArticle",
            "title": "New specimens of Pliocene bats (Mammalia, Chiroptera, Vespertilionidae and Molossidae) from the Meade Basin, Kansas, U.S.A.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nicholas J.",
                    "lastName": "Czaplewski"
                },
                {
                    "creatorType": "author",
