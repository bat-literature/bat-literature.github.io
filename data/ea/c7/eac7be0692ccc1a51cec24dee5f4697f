            "title": "Thumb-pads up—a new species of thick-thumbed bat from Sumatra (Chiroptera: Vespertilionidae: Glischropus)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Gábor",
                    "lastName": "Csorba"
                },
