            "itemType": "journalArticle",
            "title": "No evidence for spectral jamming avoidance in echolocation behavior of foraging pipistrelle bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Simone",
                    "lastName": "Götze"
                },
                {
                    "creatorType": "author",
