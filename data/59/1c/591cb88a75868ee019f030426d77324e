            "itemType": "journalArticle",
            "title": "A nocturnal mammal, the greater mouse-eared bat, calibrates a magnetic compass by the sun",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Richard A.",
                    "lastName": "Holland"
                },
                {
                    "creatorType": "author",
