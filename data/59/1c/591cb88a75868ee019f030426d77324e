            "itemType": "journalArticle",
            "title": "A functional role of the sky’s polarization pattern for orientation in the greater mouse-eared bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Stefan",
                    "lastName": "Greif"
                },
                {
                    "creatorType": "author",
