            "title": "Bats perceptually weight prey cues across sensory systems when hunting in noise",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D. G. E.",
                    "lastName": "Gomes"
                },
                {
                    "creatorType": "author",
