            "title": "Understory bat roosts, availability and occupation patterns in a Neotropical rainforest of Costa Rica",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "David",
                    "lastName": "Villalobos-Chaves"
                },
                {
                    "creatorType": "author",
