            "itemType": "journalArticle",
            "title": "Use of Integrated Modeling to Enhance Estimates of Population Dynamics Obtained from Limited Data",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Michael",
                    "lastName": "Schaub"
                },
                {
                    "creatorType": "author",
                    "firstName": "Olivier",
