            "title": "Transposable Elements Activity is Positively Related to Rate of Speciation in Mammals",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marco",
                    "lastName": "Ricci"
                },
                {
                    "creatorType": "author",
