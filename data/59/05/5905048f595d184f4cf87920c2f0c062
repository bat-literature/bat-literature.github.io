        "data": {
            "key": "4RSA7Q8N",
            "version": 58463,
            "itemType": "journalArticle",
            "title": "Three flying fox (Pteropodidae: Pteropus rufus) roosts, three conservation challenges in southeastern Madagascar",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Vn",
                    "lastName": "Rahaingodrahety"
                },
                {
                    "creatorType": "author",
                    "firstName": "D",
                    "lastName": "Andriafidison"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jh",
