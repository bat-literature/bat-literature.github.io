            "itemType": "journalArticle",
            "title": "Value and benefit distribution of pollination services provided by bats in the production of cactus fruits in central Mexico",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Constance J.",
                    "lastName": "Tremlett"
                },
