            "itemType": "journalArticle",
            "title": "Using eDNA for mammal inventories still needs naturalist expertise, a meta‐analysis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pauline",
                    "lastName": "Van Leeuwen"
                },
                {
                    "creatorType": "author",
                    "firstName": "Johan",
                    "lastName": "Michaux"
