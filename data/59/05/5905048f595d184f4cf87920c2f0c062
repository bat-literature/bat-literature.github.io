            "title": "Variación Temporal de Gremios Tróficos de un Ensamble de Murciélagos en un Agro-paisaje de Bosque Seco en Costa Rica",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marco A.",
                    "lastName": "Ramírez-Vargas"
                },
                {
                    "creatorType": "author",
