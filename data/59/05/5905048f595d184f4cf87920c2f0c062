            "itemType": "journalArticle",
            "title": "Viral metacommunities associated to bats and rodents at different spatial scales",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "F.",
                    "lastName": "Nieto-Rabiela"
                },
                {
                    "creatorType": "author",
                    "firstName": "G.",
                    "lastName": "Suzán"
