            "title": "Habitat fragmentation is associated with dietary shifts and microbiota variability in common vampire bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Melissa R.",
                    "lastName": "Ingala"
                },
                {
                    "creatorType": "author",
