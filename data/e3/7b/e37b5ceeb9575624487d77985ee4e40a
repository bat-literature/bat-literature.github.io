            "itemType": "journalArticle",
            "title": "Community structure of a Neotropical bat fauna as revealed by stable isotope analysis: Not all species fit neatly into predicted guilds",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Phillip J.",
                    "lastName": "Oelbaum"
                },
                {
                    "creatorType": "author",
