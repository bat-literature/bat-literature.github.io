            "itemType": "preprint",
            "title": "Targeted sequence capture outperforms RNA-Seq and degenerate-primer PCR cloning for sequencing the largest mammalian multi-gene family",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Laurel R.",
                    "lastName": "Yohe"
                },
                {
                    "creatorType": "author",
