            "itemType": "journalArticle",
            "title": "Dietary influences on head and neck ranges of motion in neotropical bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "N.",
                    "lastName": "Grider‐Potter"
                },
                {
                    "creatorType": "author",
                    "firstName": "A.",
                    "lastName": "Rummel"
