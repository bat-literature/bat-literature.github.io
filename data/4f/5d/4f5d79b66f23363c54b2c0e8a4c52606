            "title": "Experimental infection of Artibeus intermedius with a vampire bat rabies virus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Cirani",
                    "lastName": "Obregón-Morales"
                },
                {
                    "creatorType": "author",
