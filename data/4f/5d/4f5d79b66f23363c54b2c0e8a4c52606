        "data": {
            "key": "F7WPDTUW",
            "version": 56211,
            "itemType": "journalArticle",
            "title": "THE ROLE OF WILD MAMMALS IN THE MAINTENANCE OF RIFT VALLEY FEVER VIRUS",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marie-Marie",
                    "lastName": "Olive"
                },
                {
                    "creatorType": "author",
                    "firstName": "Steven M.",
                    "lastName": "Goodman"
