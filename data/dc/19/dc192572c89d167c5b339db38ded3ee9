            "itemType": "journalArticle",
            "title": "Meta-analysis reveals glucocorticoid levels reflect variation in metabolic rate, not ‘stress’",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Blanca",
                    "lastName": "Jimeno"
                },
                {
                    "creatorType": "author",
                    "firstName": "Simon",
