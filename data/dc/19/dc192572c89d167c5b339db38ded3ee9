            "title": "Long-term microclimate measurements add further evidence that there is no “optimal” temperature for bat hibernation",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Justin G.",
                    "lastName": "Boyles"
                },
                {
                    "creatorType": "author",
                    "firstName": "Esmarie",
                    "lastName": "Boyles"
                },
                {
                    "creatorType": "author",
