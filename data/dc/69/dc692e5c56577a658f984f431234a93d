            "itemType": "journalArticle",
            "title": "Influence of signal direction on sonar interference",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Amanda M.",
                    "lastName": "Adams"
                },
                {
                    "creatorType": "author",
