            "itemType": "journalArticle",
            "title": "Human viruses: discovery and emergence",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mark",
                    "lastName": "Woolhouse"
                },
                {
                    "creatorType": "author",
