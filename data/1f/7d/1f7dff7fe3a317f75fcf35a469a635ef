            "key": "NFEILLSU",
            "version": 29295,
            "itemType": "journalArticle",
            "title": "Environmental and climatic reconstruction of MIS 3 in northwestern Europe using the small-mammal assemblage from Caverne Marie-Jeanne (Hastière-Lavaux, Belgium)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Juan Manuel",
                    "lastName": "López-García"
                },
                {
                    "creatorType": "author",
                    "firstName": "Hugues-Alexandre",
                    "lastName": "Blain"
                },
                {
                    "creatorType": "author",
                    "firstName": "Iván",
