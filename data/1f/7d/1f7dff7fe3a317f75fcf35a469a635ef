            "itemType": "journalArticle",
            "title": "The De Nadale Cave (Zovencedo, Berici Hills, northeastern Italy): A small-mammal fauna from near the onset of Marine Isotope Stage 4 and its palaeoclimatic implications",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Juan Manuel",
                    "lastName": "López-García"
                },
                {
                    "creatorType": "author",
