            "title": "Bacterial Communities in Fecal Samples of Myotis chiloensis from Southern, Chile",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Kattia",
                    "lastName": "Núñez-Montero"
                },
                {
                    "creatorType": "author",
