            "itemType": "journalArticle",
            "title": "Bat mortality in wind farms of southern Europe: temporal patterns and implications in the current context of climate change",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "María Del Mar",
                    "lastName": "Salguero"
                },
                {
                    "creatorType": "author",
