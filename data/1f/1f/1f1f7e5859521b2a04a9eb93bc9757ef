            "itemType": "journalArticle",
            "title": "BATS, BACTERIA, AND BAT SMELL: SEX-SPECIFIC DIVERSITY OF MICROBES IN A SEXUALLY SELECTED SCENT ORGAN",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christian C.",
                    "lastName": "Voigt"
                },
                {
                    "creatorType": "author",
