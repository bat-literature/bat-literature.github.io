            "itemType": "journalArticle",
            "title": "First Detection of Bat Astroviruses (BtAstVs) among Bats in Poland: The Genetic BtAstVs Diversity Reveals Multiple Co-Infection of Bats with Different Strains",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Anna",
                    "lastName": "Orłowska"
                },
                {
                    "creatorType": "author",
                    "firstName": "Marcin",
