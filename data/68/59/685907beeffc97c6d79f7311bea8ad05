        "data": {
            "key": "LUANDCKG",
            "version": 53697,
            "itemType": "conferencePaper",
            "title": "Classification of flowers by bats: comparison with the radar case",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alessio",
                    "lastName": "Balleri"
                },
                {
                    "creatorType": "author",
