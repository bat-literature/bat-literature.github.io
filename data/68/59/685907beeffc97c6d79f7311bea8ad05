            "itemType": "journalArticle",
            "title": "Histochemical and immunohistochemical evidence for a gradient in gastric juice production in the greater horseshoe bat, Rhinolophus ferrumequinum (Schreber, 1774)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Giovanni",
                    "lastName": "Scillitani"
                },
                {
                    "creatorType": "author",
                    "firstName": "Sara",
                    "lastName": "Zizza"
                },
                {
                    "creatorType": "author",
