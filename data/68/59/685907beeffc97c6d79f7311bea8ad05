        "data": {
            "key": "JTZH6KKI",
            "version": 53814,
            "itemType": "journalArticle",
            "title": "Bats of the Reserva Nacional Allpahuayo-Mishana, Northeastern Peru, with Notes on Community Structure",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christine L.",
