            "itemType": "journalArticle",
            "title": "A genomic portrait of Sturnira parvidens: mitochondrial chromosome, repetitive elements, and microsatellite discovery",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "J Antonio",
                    "lastName": "Baeza"
                },
                {
