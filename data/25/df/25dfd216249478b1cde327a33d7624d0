            "title": "Estimating bat abundance and diversity in a modified tropical environment in central Ghana",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Evans E",
                    "lastName": "Nkrumah"
                },
                {
                    "creatorType": "author",
