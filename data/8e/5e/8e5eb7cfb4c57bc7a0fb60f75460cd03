            "itemType": "journalArticle",
            "title": "Faeces as a novel material to estimate lyssavirus prevalence in bat populations",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lineke",
                    "lastName": "Begeman"
                },
                {
                    "creatorType": "author",
