            "itemType": "journalArticle",
            "title": "Impact assessment research: use and misuse of habituation, sensitisation and tolerance in describing wildlife responses to anthropogenic stimuli",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "L",
                    "lastName": "Bejder"
                },
                {
                    "creatorType": "author",
                    "firstName": "A",
                    "lastName": "Samuels"
                },
                {
                    "creatorType": "author",
