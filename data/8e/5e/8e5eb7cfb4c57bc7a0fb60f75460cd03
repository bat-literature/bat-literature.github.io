            "title": "What Makes a Host Profitable? Parasites Balance Host Nutritive Resources against Immunity",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pierre",
                    "lastName": "Bize"
                },
                {
                    "creatorType": "author",
                    "firstName": "Caroline",
