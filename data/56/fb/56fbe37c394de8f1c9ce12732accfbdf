            "itemType": "journalArticle",
            "title": "An investigation into the role of the Mauritian flying fox, Pteropus niger, in forest regeneration",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Dorte Friis",
                    "lastName": "Nyhagen"
