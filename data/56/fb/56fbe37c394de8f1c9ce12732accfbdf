            "itemType": "journalArticle",
            "title": "Pathophysiology of white-nose syndrome in bats: a mechanistic model linking wing damage to mortality",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lisa",
                    "lastName": "Warnecke"
                },
                {
                    "creatorType": "author",
                    "firstName": "James M.",
