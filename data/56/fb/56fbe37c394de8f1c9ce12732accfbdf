            "itemType": "journalArticle",
            "title": "Sensitivity of insectivorous bats to urbanization: Implications for suburban conservation planning",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Caragh G.",
                    "lastName": "Threlfall"
                },
                {
                    "creatorType": "author",
