        "data": {
            "key": "CS4UBQN6",
            "version": 83231,
            "itemType": "journalArticle",
            "title": "Breaking the trade-off: rainforest bats maximize bandwidth and repetition rate of echolocation calls as they approach prey",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniela A.",
                    "lastName": "Schmieder"
                },
                {
                    "creatorType": "author",
                    "firstName": "Tigga",
