            "title": "Dramatic decline in bat species richness in Singapore, with implications for Southeast Asia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "David J.W.",
                    "lastName": "Lane"
                },
                {
                    "creatorType": "author",
