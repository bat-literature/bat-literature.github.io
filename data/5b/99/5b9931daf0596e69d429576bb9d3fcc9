            "itemType": "journalArticle",
            "title": "Shallow genetic differentiation in Miniopterus schreibersii (Chiroptera: Vespertilionidae) indicates a relatively recent re-colonization of Europe from a single glacial refugium",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Andrzej",
                    "lastName": "Furman"
                },
                {
