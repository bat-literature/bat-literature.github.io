        "data": {
            "key": "XQSBBQIP",
            "version": 53955,
            "itemType": "journalArticle",
            "title": "Foraging and public information use in common pipistrelle bats (Pipistrellus pipistrellus): a field experiment",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marlotte N.",
                    "lastName": "Jonker"
                },
                {
                    "creatorType": "author",
                    "firstName": "Willem F. De",
                    "lastName": "Boer"
