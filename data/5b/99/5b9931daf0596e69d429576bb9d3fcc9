            "itemType": "journalArticle",
            "title": "Echolocation Calls of the Bats of Trinidad, West Indies: Is Guild Membership Reflected in Echolocation Signal Design?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Dorothea V. V.",
                    "lastName": "Pio"
                },
                {
                    "creatorType": "author",
                    "firstName": "Frank M.",
