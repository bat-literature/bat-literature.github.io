            "title": "Evaluation of maternal features as indicators of asynchronous embryonic development in Miniopterus natalensis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mandy K.",
                    "lastName": "Mason"
                },
                {
                    "creatorType": "author",
