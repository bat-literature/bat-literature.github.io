            "itemType": "journalArticle",
            "title": "Selection of Maternity Roosts by Myotis bechsteinii (Kuhl, 1817) in the Southwestern Iberian Peninsula",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "María",
                    "lastName": "Napal"
