            "title": "Insectivorous Bat Activity at Cenotes in the Yucatan Peninsula, Mexico",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "M. Cristina",
                    "lastName": "MacSwiney G."
                },
                {
                    "creatorType": "author",
