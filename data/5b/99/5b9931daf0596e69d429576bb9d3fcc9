            "itemType": "journalArticle",
            "title": "Taxonomy of the genus Otonycteris (Chiroptera: Vespertilionidae: Plecotini) as inferred from morphological and mtDNA data",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Petr",
