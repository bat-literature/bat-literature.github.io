            "title": "Habitat selection in Nathusius’ pipistrelle (Pipistrellus nathusii): the importance of wetlands",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Carles",
                    "lastName": "Flaquer"
                },
                {
                    "creatorType": "author",
                    "firstName": "Xavier",
