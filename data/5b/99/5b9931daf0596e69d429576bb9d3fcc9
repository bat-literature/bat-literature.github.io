            "title": "Genetic similarity amongst phenotypically diverse little free-tailed bats, Chaerephon pumilus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "David S.",
                    "lastName": "Jacobs"
                },
                {
                    "creatorType": "author",
                    "firstName": "Geeta N.",
