            "itemType": "journalArticle",
            "title": "Identification of bat species in Greece from their echolocation calls",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Eleni",
                    "lastName": "Papadatou"
                },
                {
                    "creatorType": "author",
