            "title": "Seasonal Survival Probabilities Suggest Low Migration Mortality in Migrating Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Simone",
                    "lastName": "Giavi"
                },
                {
                    "creatorType": "author",
