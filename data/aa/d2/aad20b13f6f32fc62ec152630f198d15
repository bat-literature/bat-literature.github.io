            "itemType": "journalArticle",
            "title": "Relating bat species presence to simple habitat measures in a central Appalachian forest",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "W. Mark",
                    "lastName": "Ford"
                },
                {
                    "creatorType": "author",
