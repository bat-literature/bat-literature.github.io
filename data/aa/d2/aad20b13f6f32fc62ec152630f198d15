            "itemType": "journalArticle",
            "title": "Pollination Biology and the Relative Importance of Nocturnal and Diurnal Pollinators in Three Species of Sonoran Desert Columnar Cacti",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Theodore H.",
