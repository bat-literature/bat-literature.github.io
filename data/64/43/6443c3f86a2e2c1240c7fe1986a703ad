            "version": 28913,
            "itemType": "journalArticle",
            "title": "Co-occurrence of Ectoparasites (Insecta and Arachnida) on Bats (Chiroptera) in an Atlantic Forest Remnant, Southeastern Brazil",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Elizabete Captivo",
                    "lastName": "Lourenço"
                },
                {
                    "creatorType": "author",
                    "firstName": "Luiz Antonio Costa",
                    "lastName": "Gomes"
                },
                {
                    "creatorType": "author",
                    "firstName": "Amanda De Oliveira",
