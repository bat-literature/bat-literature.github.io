            "itemType": "journalArticle",
            "title": "Interaction between Pteronotus fulvus (Chiroptera: Mormoopidae) and Nyctantonina azteca (Blattodea: Nyctiboridae). A Strange Case of Predation or Parasitism?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ricardo",
                    "lastName": "Lopez-Wilchis"
                },
                {
                    "creatorType": "author",
                    "firstName": "Julio C.",
                    "lastName": "Estrada-Álvarez"
                },
                {
                    "creatorType": "author",
