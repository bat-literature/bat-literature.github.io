            "itemType": "journalArticle",
            "title": "High frequency of trypanosomatids in gallery forest bats of a Neotropical savanna",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "João Lucas M.",
                    "lastName": "Lourenço"
                },
                {
