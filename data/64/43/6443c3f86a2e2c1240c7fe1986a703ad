            "title": "Diversidad y estructura genética de artibeus jamaicensis (chiroptera: phyllostomidae) en Chiapas, México",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Viridiana",
                    "lastName": "Llaven Macías"
                },
                {
                    "creatorType": "author",
                    "firstName": "Lorena",
                    "lastName": "Ruiz Montoya"
                },
                {
                    "creatorType": "author",
