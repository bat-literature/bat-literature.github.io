                    "lastName": "Silva"
                },
                {
                    "creatorType": "author",
                    "firstName": "Amanda C.",
                    "lastName": "Oliveira"
                },
                {
                    "creatorType": "author",
                    "firstName": "Vagner J.",
                    "lastName": "Mendonça"
                },
                {
                    "creatorType": "author",
