                    "firstName": "Iain",
                    "lastName": "Martyn"
                },
                {
                    "creatorType": "author",
                    "firstName": "Tyler S",
                    "lastName": "Kuhn"
                },
                {
                    "creatorType": "author",
                    "firstName": "Arne O",
