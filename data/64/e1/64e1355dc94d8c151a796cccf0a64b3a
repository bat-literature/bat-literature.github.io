        "data": {
            "key": "MKW4SNVI",
            "version": 65475,
            "itemType": "journalArticle",
            "title": "A comparative analysis of components incorporated in conservation priority assessments: a case study based on South African species of terrestrial mammals.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "M",
                    "lastName": "Keith"
                },
                {
                    "creatorType": "author",
