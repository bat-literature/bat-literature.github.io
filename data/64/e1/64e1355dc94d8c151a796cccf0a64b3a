            "itemType": "journalArticle",
            "title": "A Checklist of Nycteribiid and Streblid Bat Flies (Diptera: Nycteribiidae and Streblidae) from Thailand with Thirteen New Records for the Country",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Abdulloh",
