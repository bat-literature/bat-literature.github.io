            "itemType": "journalArticle",
            "title": "Ultraviolet light reveals cryptic markings in Greater Antillean long-tongued bats (Monophyllus redmani) from Puerto Rico.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Allen",
                    "lastName": "Kurta"
                },
                {
                    "creatorType": "author",
