            "itemType": "journalArticle",
            "title": "Microbiome analysis among bats describes influences of host phylogeny, life history, physiology and geography",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Caleb D.",
                    "lastName": "Phillips"
                },
                {
                    "creatorType": "author",
