            "itemType": "journalArticle",
            "title": "The feeding ecology of Eidolon dupreanum (Pteropodidae) in eastern Madagascar",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Monica",
                    "lastName": "Picot"
                },
                {
                    "creatorType": "author",
                    "firstName": "Richard K. B.",
                    "lastName": "Jenkins"
                },
