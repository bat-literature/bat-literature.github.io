        "data": {
            "key": "ADUJQDD2",
            "version": 62319,
            "itemType": "journalArticle",
            "title": "Diversification among New World leaf-nosed bats: an evolutionary hypothesis and classification inferred from digenomic congruence of DNA sequence.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Robert J",
                    "lastName": "Baker"
                },
                {
                    "creatorType": "author",
                    "firstName": "Steven R",
