            "itemType": "journalArticle",
            "title": "Large-seeded plants dispersed by tent-roosting bats along an altitudinal gradient in Costa Rica",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ricardo",
                    "lastName": "Sánchez-Calderón"
                },
                {
                    "creatorType": "author",
