            "title": "Noteworthy County Records for 14 Bat Species Based on Specimens Submitted to the Texas Department of State Health Services",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Krysta D",
                    "lastName": "Demere"
                },
                {
                    "creatorType": "author",
