            "itemType": "journalArticle",
            "title": "Evaluation of Paraphyletic Assemblages within Lonchophyllinae, with Description of a New Tribe and Genus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Julie A.",
                    "lastName": "Parlos"
                },
                {
                    "creatorType": "author",
                    "firstName": "Robert M.",
