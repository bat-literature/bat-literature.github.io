            "title": "Spatial distribution and prediction of seed production by Eucalyptus microcarpa in a fragmented landscape",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Peter A.",
                    "lastName": "Vesk"
                },
                {
                    "creatorType": "author",
