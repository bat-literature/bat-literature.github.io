            "itemType": "journalArticle",
            "title": "Seasonal variations in the morphology of the seminal vesicles of the African straw‐coloured fruit bat (Eidolon helvum)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Clifford Nwabugwu",
                    "lastName": "Abiaezute"
