            "title": "Ecological Correlates of Range Size in the Tent-Making Bat Artibeus watsoni",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Gloriana",
                    "lastName": "Chaverri"
                },
                {
                    "creatorType": "author",
