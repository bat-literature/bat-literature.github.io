            "itemType": "journalArticle",
            "title": "Comparative light and scanning electron microscopic studies of the lenses in the insectivorous bat (Pipistrellus kuhlii) and Egyptian fruit bat (Rousettus aegyptiacus)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Asmaa",
