            "title": "High Dispersal and Generalist Habits of the Bat Artibeus jamaicensis on Cozumel Island, Mexico: An Assessment Using Molecular Genetics",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ella",
                    "lastName": "Vázquez-Domínguez"
                },
                {
                    "creatorType": "author",
