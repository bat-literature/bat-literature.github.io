            "title": "Identification and characterization of the contact zone between short-tailed shrews (Blarina) in Iowa and Missouri",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "C.W.",
                    "lastName": "Thompson"
                },
                {
                    "creatorType": "author",
                    "firstName": "R.S.",
                    "lastName": "Pfau"
                },
                {
                    "creatorType": "author",
                    "firstName": "J.R.",
