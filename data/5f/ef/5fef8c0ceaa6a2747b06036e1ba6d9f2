            "title": "Armillifer-Infected Snakes Sold at Congolese Bushmeat Markets Represent an Emerging Zoonotic Threat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Richard",
                    "lastName": "Hardi"
                },
                {
                    "creatorType": "author",
                    "firstName": "Gergely",
