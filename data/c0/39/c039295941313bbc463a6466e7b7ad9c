            "itemType": "journalArticle",
            "title": "Morphological and genetic diversity in a South American forest‐dependent bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sofia Marques",
                    "lastName": "Silva"
                },
                {
                    "creatorType": "author",
