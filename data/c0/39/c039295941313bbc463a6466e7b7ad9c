        "data": {
            "key": "98A2CN2L",
            "version": 11817,
            "itemType": "journalArticle",
            "title": "Evolutionary Change in the Brain Size of Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lu",
                    "lastName": "Yao"
                },
                {
                    "creatorType": "author",
                    "firstName": "J.-P.",
                    "lastName": "Brown"
                },
                {
                    "creatorType": "author",
                    "firstName": "Marco",
                    "lastName": "Stampanoni"
                },
                {
                    "creatorType": "author",
