            "title": "Morphology, genetics and echolocation calls of the genus Kerivoula (Chiroptera: Vespertilionidae: Kerivoulinae) in Thailand",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Bounsavane",
                    "lastName": "Douangboubpha"
                },
                {
                    "creatorType": "author",
