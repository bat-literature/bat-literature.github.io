            "title": "Prey Size and Dietary Niche of Rafinesque’s Big-Eared Bat (Corynorhinus rafinesquii)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Luke E.",
                    "lastName": "Dodd"
                },
                {
                    "creatorType": "author",
