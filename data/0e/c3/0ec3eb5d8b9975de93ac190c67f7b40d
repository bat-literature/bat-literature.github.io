            "itemType": "journalArticle",
            "title": "A Synopsis of Distribution Patterns and the Conservation of Mammal Species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "F. Russell",
                    "lastName": "Cole"
                },
                {
                    "creatorType": "author",
