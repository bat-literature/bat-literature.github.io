            "itemType": "journalArticle",
            "title": "A primate T-lymphotropic virus, PTLV-L, different from human T-lymphotropic viruses types I and II, in a wild-caught baboon (Papio hamadryas)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "P.",
                    "lastName": "Goubau"
                },
                {
                    "creatorType": "author",
                    "firstName": "M.",
                    "lastName": "Van Brussel"
                },
                {
                    "creatorType": "author",
