            "title": "Artificial light puts ecosystem services of frugivorous bats at risk",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel",
                    "lastName": "Lewanzik"
                },
                {
                    "creatorType": "author",
