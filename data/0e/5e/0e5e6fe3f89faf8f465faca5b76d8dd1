            "itemType": "journalArticle",
            "title": "Cellular location and major terminal networks of the orexinergic system in the brains of five microchiropteran species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jean-Leigh",
                    "lastName": "Kruger"
                },
                {
