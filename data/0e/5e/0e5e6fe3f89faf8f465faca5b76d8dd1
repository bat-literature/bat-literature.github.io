            "title": "The fauna of caves and other subter-ranean habitats of North Carolina, USA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Cato",
                    "lastName": "Holler, Jr"
                },
                {
                    "creatorType": "author",
