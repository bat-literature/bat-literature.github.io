            "title": "Echo feedback mediates noise-induced vocal modifications in flying bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jinhong",
                    "lastName": "Luo"
                },
                {
                    "creatorType": "author",
