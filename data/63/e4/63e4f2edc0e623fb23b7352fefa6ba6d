            "title": "Landscape structure shapes activity levels and composition of aerial insectivorous bats at different spatial scales",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Fábio",
                    "lastName": "Falcão"
                },
                {
                    "creatorType": "author",
                    "firstName": "Pavel",
