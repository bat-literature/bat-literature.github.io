            "itemType": "journalArticle",
            "title": "A first assessment of feeding habits in the fruit bat Rousettus aegyptiacus on Cyprus island",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maria Alessandra",
                    "lastName": "del Vaglio"
                },
                {
                    "creatorType": "author",
