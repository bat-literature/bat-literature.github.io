            "itemType": "journalArticle",
            "title": "Factors affecting the occupation of a colony site in Sydney, New South Wales by the Grey-headed Flying-fox Pteropus poliocephalus (Pteropodidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "K. A.",
