            "itemType": "journalArticle",
            "title": "Survival of PIT-tagged lesser short-tailed bats (Mystacina tuberculata) through an aerial 1080 pest control operation",
            "creators": [
                {
                    "creatorType": "author",
                    "name": "Department of Conservation, New Zealand"
                },
                {
                    "creatorType": "author",
                    "firstName": "Hannah",
