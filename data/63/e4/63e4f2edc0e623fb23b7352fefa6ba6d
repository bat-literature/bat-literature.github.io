            "title": "Unexpected genomic, biosynthetic and species diversity of Streptomyces bacteria from bats in Arizona and New Mexico, USA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Cooper J.",
                    "lastName": "Park"
                },
                {
                    "creatorType": "author",
                    "firstName": "Nicole A.",
                    "lastName": "Caimi"
                },
                {
                    "creatorType": "author",
                    "firstName": "Debbie C.",
                    "lastName": "Buecher"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ernest W.",
                    "lastName": "Valdez"
                },
                {
                    "creatorType": "author",
