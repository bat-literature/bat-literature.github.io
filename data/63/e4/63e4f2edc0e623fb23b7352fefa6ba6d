            "itemType": "journalArticle",
            "title": "Investigating Difficult Nodes in the Placental Mammal Tree with Expanded Taxon Sampling and Thousands of Ultraconserved Elements",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jacob A.",
                    "lastName": "Esselstyn"
