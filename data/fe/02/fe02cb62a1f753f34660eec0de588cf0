            "title": "Influence of banana plantations on bat assemblages (Chiroptera)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lia Lins",
                    "lastName": "Luz"
                },
                {
                    "creatorType": "author",
