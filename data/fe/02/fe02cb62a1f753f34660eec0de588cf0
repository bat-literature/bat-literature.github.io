            "title": "Bats in tea plantations in Sri Lanka: Species richness and distribution",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Tharaka",
                    "lastName": "Kusuminda"
                },
                {
                    "creatorType": "author",
                    "firstName": "Amani",
