            "itemType": "journalArticle",
            "title": "Electrophoretic studies of the systematic and biogeographic relationships of the Fijian bat genera Pteropus, Pteralopex, Chaerephon and Notopteris.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "S",
