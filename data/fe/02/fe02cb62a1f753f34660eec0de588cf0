            "title": "Genomic characterization of two novel polyomaviruses in Brazilian insectivorous bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Francisco Esmaile",
                    "lastName": "De Sales Lima"
                },
                {
                    "creatorType": "author",
