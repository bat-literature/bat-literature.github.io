            "version": 72009,
            "itemType": "journalArticle",
            "title": "A new species of Cynomops (Chiroptera: Molossidae) from the northwestern slope of the Andes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniela",
                    "lastName": "Arenas-Viveros"
                },
                {
                    "creatorType": "author",
