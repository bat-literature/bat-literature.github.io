            "itemType": "journalArticle",
            "title": "Tent-roosting may have driven the evolution of yellow skin coloration in Stenodermatinae bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ismael",
                    "lastName": "Galván"
                },
                {
                    "creatorType": "author",
