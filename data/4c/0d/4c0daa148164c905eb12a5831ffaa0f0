            "itemType": "journalArticle",
            "title": "Evolution of adaptive phenotypic variation patterns by direct selection for evolvability",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mihaela",
                    "lastName": "Pavlicev"
                },
                {
