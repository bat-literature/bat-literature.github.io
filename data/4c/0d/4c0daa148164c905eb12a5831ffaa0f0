            "title": "Lunar phobia in phyllostomid bats at La Ceiba, Tuxpan, Veracruz",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Juan Manuel",
                    "lastName": "Pech Canché"
                },
                {
                    "creatorType": "author",
