            "title": "Vector Competence of Eucampsipoda africana (Diptera: Nycteribiidae) for Marburg Virus Transmission in Rousettus aegyptiacus (Chiroptera: Pteropodidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Janusz T.",
                    "lastName": "Pawęska"
                },
                {
                    "creatorType": "author",
