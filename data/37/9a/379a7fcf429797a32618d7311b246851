            "itemType": "journalArticle",
            "title": "Plant Attribute Diversity, Resilience, and Ecosystem Function: The Nature and Significance of Dominant and Minor Species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Brian",
