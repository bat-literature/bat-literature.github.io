            "title": "Phenology and floral visitors of two sympatric Heliconia species in the Brazilian Atlantic forest",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Denise Dias",
                    "lastName": "Da Cruz"
                },
                {
                    "creatorType": "author",
