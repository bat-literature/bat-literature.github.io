            "title": "PHYSIOLOGICAL RESPONSES TO AMBIENT TEMPERATURE MANIPULATION BY THREE SPECIES OF BATS FROM ANDEAN CLOUD FORESTS",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pascual J.",
                    "lastName": "Soriano"
                },
