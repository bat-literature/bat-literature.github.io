            "title": "Less Is More in Mammalian Phylogenomics: AT-Rich Genes Minimize Tree Conflicts and Unravel the Root of Placental Mammals",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jonathan",
                    "lastName": "Romiguier"
                },
                {
                    "creatorType": "author",
                    "firstName": "Vincent",
                    "lastName": "Ranwez"
                },
                {
                    "creatorType": "author",
