            "itemType": "journalArticle",
            "title": "Interspecific competition in bats and diet shifts in response to white‐nose syndrome",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Derek E.",
                    "lastName": "Morningstar"
                },
                {
                    "creatorType": "author",
