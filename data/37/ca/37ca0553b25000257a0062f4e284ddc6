            "itemType": "journalArticle",
            "title": "Intense natural selection preceded the invasion of new adaptive zones during the radiation of New World leaf-nosed bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniela M.",
                    "lastName": "Rossoni"
                },
                {
                    "creatorType": "author",
