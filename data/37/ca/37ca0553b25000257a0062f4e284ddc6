            "title": "Limitations of acoustic monitoring at wind turbines to evaluate fatality risk of bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christian C.",
                    "lastName": "Voigt"
                },
                {
                    "creatorType": "author",
