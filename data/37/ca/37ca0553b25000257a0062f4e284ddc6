            "itemType": "journalArticle",
            "title": "Latitudinal Diversity Gradients in New World Bats: Are They a Consequence of Niche Conservatism?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maria João",
                    "lastName": "Ramos Pereira"
                },
                {
                    "creatorType": "author",
