            "itemType": "journalArticle",
            "title": "Island bat diets: does it matter more who you are or where you live?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jodi L.",
                    "lastName": "Sedlock"
                },
                {
                    "creatorType": "author",
