            "itemType": "journalArticle",
            "title": "Eptesicus fuscus Orthorubulavirus, a Close Relative of Human Parainfluenza Virus 4, Discovered in a Bat in South Dakota",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ben M.",
                    "lastName": "Hause"
                },
                {
                    "creatorType": "author",
                    "firstName": "Eric",
