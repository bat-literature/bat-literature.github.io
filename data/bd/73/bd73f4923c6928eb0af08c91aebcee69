                },
                {
                    "creatorType": "author",
                    "firstName": "Teague",
                    "lastName": "O'Mara"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jon",
                    "lastName": "Flanders"
                },
                {
                    "creatorType": "author",
                    "firstName": "Sourette Said Ali",
                    "lastName": "Chaihane"
                },
                {
                    "creatorType": "author",
                    "firstName": "Owen T.",
