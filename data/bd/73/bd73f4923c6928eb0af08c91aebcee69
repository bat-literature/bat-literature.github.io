            "itemType": "journalArticle",
            "title": "Home ranges, feeding sites, and daily movement behavior of the highly threatened Livingstone's fruit bat revealed through tracking",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Isabella",
                    "lastName": "Mandl"
                },
                {
                    "creatorType": "author",
                    "firstName": "Badrane Ben Ali",
