            "title": "Seasonal trends and population status of the highly threatened Pteropus livingstonii in the Comoros archipelago",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Isabella",
                    "lastName": "Mandl"
                },
                {
                    "creatorType": "author",
                    "firstName": "Amelaid",
