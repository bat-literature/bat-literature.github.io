            "title": "Population‐level scaling of avian migration speed with body size and migration distance for powered fliers",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Frank A.",
                    "lastName": "La Sorte"
                },
                {
                    "creatorType": "author",
