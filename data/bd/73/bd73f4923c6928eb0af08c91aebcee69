                {
                    "creatorType": "author",
                    "firstName": "Nastazia",
                    "lastName": "Mohamed"
                },
                {
                    "creatorType": "author",
                    "firstName": "Abdoulkader",
                    "lastName": "Fardane"
                },
                {
                    "creatorType": "author",
                    "firstName": "Samirou",
                    "lastName": "Soulaïmana"
