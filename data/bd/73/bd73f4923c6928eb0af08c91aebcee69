            "title": "Ecological Energetics of an Abundant Aerial Insectivore, the Purple Martin",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jeffrey F.",
                    "lastName": "Kelly"
                },
                {
                    "creatorType": "author",
