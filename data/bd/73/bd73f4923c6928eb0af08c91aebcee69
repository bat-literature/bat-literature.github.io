            "title": "Conservation Status of North American Birds in the Face of Future Climate Change",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Gary M.",
                    "lastName": "Langham"
                },
                {
                    "creatorType": "author",
                    "firstName": "Justin G.",
                    "lastName": "Schuetz"
                },
                {
                    "creatorType": "author",
                    "firstName": "Trisha",
                    "lastName": "Distler"
                },
                {
                    "creatorType": "author",
                    "firstName": "Candan U.",
