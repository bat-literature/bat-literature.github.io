            "title": "Modelling the spatial concentrations of bird migration to assess conflicts with wind turbines",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Felix",
                    "lastName": "Liechti"
                },
                {
                    "creatorType": "author",
