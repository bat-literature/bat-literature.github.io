            "title": "Heterogeneity Shapes Invasion: Host Size And Environment Influence Susceptibility To A Nonnative Pathogen",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Matthew J.",
                    "lastName": "Kauffman"
                },
                {
                    "creatorType": "author",
                    "firstName": "Erik S.",
