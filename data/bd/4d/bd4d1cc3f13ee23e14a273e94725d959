            "itemType": "journalArticle",
            "title": "Estimating bat fatality at a Texas wind energy facility: implications transcending the United States–Mexico border",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sara P",
                    "lastName": "Weaver"
                },
                {
                    "creatorType": "author",
