            "itemType": "journalArticle",
            "title": "Ethnobiology of Bats: Exploring Human-Bat Inter-Relationships in a Rapidly Changing World",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ricardo",
                    "lastName": "Rocha"
