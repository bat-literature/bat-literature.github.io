            "title": "Oral Sampling of Little Brown Bat (Myotis lucifugus) Maternity Colonies for SARS-CoV-2 in the Northeast and Mid-Atlantic, USA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Megan L.",
                    "lastName": "Moran"
                },
                {
                    "creatorType": "author",
                    "firstName": "William",
