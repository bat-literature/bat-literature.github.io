            "title": "ESTUDIO DE LA VARIACIÓN DE PERFILES HEMATOLÓGICOS DE MURCIÉLAGOS",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Evaristo",
                    "lastName": "Villalba-Alemán"
                },
                {
                    "creatorType": "author",
