        "data": {
            "key": "KGR5E2VB",
            "version": 58541,
            "itemType": "journalArticle",
            "title": "Morphological assembly mechanisms in Neotropical bat assemblages and ensembles within a landscape",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Claudia E.",
                    "lastName": "Moreno"
                },
                {
                    "creatorType": "author",
                    "firstName": "Héctor T.",
                    "lastName": "Arita"
