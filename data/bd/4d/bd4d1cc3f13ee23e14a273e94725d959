            "itemType": "journalArticle",
            "title": "Evaluating multiple determinants of the structure of plant–animal mutualistic networks",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Diego P.",
                    "lastName": "Vázquez"
                },
                {
                    "creatorType": "author",
