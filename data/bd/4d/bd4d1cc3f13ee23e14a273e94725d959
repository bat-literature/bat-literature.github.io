            "itemType": "journalArticle",
            "title": "Morphometric and morphological variation in Myotis simus Thomas (Chiroptera, Vespertilionidae), with an appraisal of the identity of Myotis guaycuru Proença based on the analysis of the type material",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ricardo",
                    "lastName": "Moratelli"
                },
                {
                    "creatorType": "author",
