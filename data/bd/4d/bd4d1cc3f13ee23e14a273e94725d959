            "title": "Current and potential distribution of Myotis simus (Chiroptera, Vespertilionidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ricardo",
                    "lastName": "Moratelli"
                },
                {
                    "creatorType": "author",
