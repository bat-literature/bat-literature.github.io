            "itemType": "journalArticle",
            "title": "Evolution of litter size in bats and its influence on longevity and roosting ecology",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Guilherme Siniciato Terra",
                    "lastName": "Garbino"
                },
                {
                    "creatorType": "author",
                    "firstName": "Anderson",
