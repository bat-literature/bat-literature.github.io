            "title": "Evidence of Antimicrobial Resistance in Bats and Its Planetary Health Impact for Surveillance of Zoonotic Spillover Events: A Scoping Review",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Popy",
                    "lastName": "Devnath"
                },
                {
                    "creatorType": "author",
                    "firstName": "Nabil",
                    "lastName": "Karah"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jay P.",
