            "title": "Simplifying a wing: diversity and functional consequences of digital joint reduction in bat wings",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Joseph W.",
                    "lastName": "Bahlman"
                },
                {
                    "creatorType": "author",
