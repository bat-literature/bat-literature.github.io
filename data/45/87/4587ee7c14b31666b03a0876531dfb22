            "title": "Histochemical Determination of Muscle Fiber Types in Primary Flight Muscles of Miniopterus schreibersi",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Suna",
                    "lastName": "Cebesoy"
                },
                {
                    "creatorType": "author",
                    "firstName": "Mehmet",
