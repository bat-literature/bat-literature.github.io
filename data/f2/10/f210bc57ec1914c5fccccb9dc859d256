            "itemType": "journalArticle",
            "title": "Development of a species identification system of Japanese bats from echolocation calls using convolutional neural networks",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Keigo",
                    "lastName": "Kobayashi"
                },
                {
