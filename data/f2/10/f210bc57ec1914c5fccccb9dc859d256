            "itemType": "journalArticle",
            "title": "When Viruses Don’t Go Viral: The Importance of Host Phylogeographic Structure in the Spatial Spread of Arenaviruses",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sophie",
                    "lastName": "Gryseels"
                },
                {
                    "creatorType": "author",
