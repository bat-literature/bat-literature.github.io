            "itemType": "journalArticle",
            "title": "Effects of Artificial Roosts for Frugivorous Bats on Seed Dispersal in a Neotropical Forest Pasture Mosaic",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Detlev H.",
                    "lastName": "Kelm"
                },
                {
                    "creatorType": "author",
