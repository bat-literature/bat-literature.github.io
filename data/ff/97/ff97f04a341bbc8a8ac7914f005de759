        "data": {
            "key": "WSC8R46T",
            "version": 42631,
            "itemType": "journalArticle",
            "title": "The role of secondary trees in Mediterranean mature forests for the conservation of the forest-dwelling bat Myotis alcathoe. Are current logging guidelines appropriate?",
            "creators": [
                {
                    "creatorType": "author",
