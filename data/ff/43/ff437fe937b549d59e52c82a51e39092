            "title": "Bird migration flight altitudes studied by a network of operational weather radars",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Adriaan M.",
                    "lastName": "Dokter"
                },
                {
                    "creatorType": "author",
