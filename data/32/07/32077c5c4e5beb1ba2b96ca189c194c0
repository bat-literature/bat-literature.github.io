            "itemType": "journalArticle",
            "title": "Seed Dispersal by Phyllostomid Bats in Two Contrasting Vegetation Types in a Mesoamerican Reserve",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alejandro A.",
                    "lastName": "Castro-Luna"
                },
                {
                    "creatorType": "author",
