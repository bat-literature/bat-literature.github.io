            "itemType": "journalArticle",
            "title": "Prey Selection by Rhinolophus hipposideros (Chiroptera, Rhinolophidae) in a Modified Forest in Southwest Europe",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ana",
                    "lastName": "Lino"
                },
                {
                    "creatorType": "author",
