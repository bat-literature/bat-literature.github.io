            "itemType": "journalArticle",
            "title": "Variation of mitochondrial DNA in the Hipposideros caffer complex (Chiroptera: Hipposideridae) and its taxonomic implications",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Peter",
                    "lastName": "Vallo"
                },
                {
                    "creatorType": "author",
