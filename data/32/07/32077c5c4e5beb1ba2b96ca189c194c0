            "itemType": "journalArticle",
            "title": "The Vocal Repertoire of Two Sympatric Species of Nectar-Feeding Bats (Glossophaga soricina and G. commissarisi)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mirjam",
