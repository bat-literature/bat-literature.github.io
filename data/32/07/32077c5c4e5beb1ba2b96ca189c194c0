            "itemType": "journalArticle",
            "title": "Prey Selection by Myotis myotis (Vespertilionidae) in a Mediterranean Region",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maria João Ramos",
                    "lastName": "Pereira"
                },
                {
                    "creatorType": "author",
                    "firstName": "Hugo",
