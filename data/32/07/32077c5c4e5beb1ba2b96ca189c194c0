            "itemType": "journalArticle",
            "title": "Reconstructing the Genomic Diversity of a Widespread Sub-Saharan Bat (Pteropodidae: Eidolon helvum) Using Archival Museum Collections",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Brian",
