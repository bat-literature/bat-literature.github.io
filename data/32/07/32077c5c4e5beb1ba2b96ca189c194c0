            "title": "Taxonomic Status Assessment of the Mexican Populations of Funnel-Eared Bats, Genus Natalus (Chiroptera: Natalidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ricardo",
                    "lastName": "López-Wilchis"
                },
                {
                    "creatorType": "author",
