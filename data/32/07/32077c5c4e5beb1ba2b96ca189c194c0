            "itemType": "journalArticle",
            "title": "The guild structure of animalivorous leaf-nosed bats of Barro Colorado Island, Panama, revisited",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Norberto P.",
                    "lastName": "Giannini"
                },
