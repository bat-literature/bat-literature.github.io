            "title": "Vampyravus orientalis Schlosser (Chiroptera) from the Early Oligocene (Rupelian), Fayum, Egypt — Body Mass, Humeral Morphology and Affinities",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Gregg F.",
                    "lastName": "Gunnell"
                },
                {
                    "creatorType": "author",
