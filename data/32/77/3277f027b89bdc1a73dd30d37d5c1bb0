        "data": {
            "key": "RLWADWV8",
            "version": 11601,
            "itemType": "journalArticle",
            "title": "Wildlife trade and the emergence of infectious diseases",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Louise",
                    "lastName": "Swift"
                },
                {
                    "creatorType": "author",
                    "firstName": "Paul R.",
                    "lastName": "Hunter"
                },
                {
                    "creatorType": "author",
