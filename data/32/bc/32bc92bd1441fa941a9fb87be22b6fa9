            "itemType": "journalArticle",
            "title": "Designing Effective Habitat Studies: Quantifying Multiple Sources of Variability in Bat Activity",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Joern",
                    "lastName": "Fischer"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jenny",
