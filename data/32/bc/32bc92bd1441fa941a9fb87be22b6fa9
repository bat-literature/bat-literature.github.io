            "itemType": "journalArticle",
            "title": "Coastal Cliffs on Islands as Foraging Habitat for Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Leonardo",
                    "lastName": "Ancillotto"
                },
                {
                    "creatorType": "author",
