            "itemType": "journalArticle",
            "title": "Habituation and ecological salience: insights into the foraging ecology of the fringed-lipped bat, Trachops cirrhosus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "M. May",
                    "lastName": "Dixon"
                },
                {
                    "creatorType": "author",
