            "title": "Prey Consumption of Insectivorous Bats in Coniferous Forests of North-Central Idaho",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Michael J.",
                    "lastName": "Lacki"
                },
                {
                    "creatorType": "author",
                    "firstName": "Joseph S.",
