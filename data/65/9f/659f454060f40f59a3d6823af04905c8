            "itemType": "journalArticle",
            "title": "The Influence of Low Intensities of Light Pollution on Bat Communities in a Semi-Natural Context",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Aurelie",
                    "lastName": "Lacoeuilhe"
