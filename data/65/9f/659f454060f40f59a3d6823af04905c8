            "itemType": "journalArticle",
            "title": "Home range size, habitat selection and roost use by the whiskered bat (Myotis mystacinus) in human-dominated montane landscapes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Korneliusz",
                    "lastName": "Kurek"
                },
                {
                    "creatorType": "author",
                    "firstName": "Olga",
                    "lastName": "Gewartowska"
                },
                {
                    "creatorType": "author",
