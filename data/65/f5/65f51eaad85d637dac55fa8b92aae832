            "title": "Conspicuous Visual Cues can Help Bats to Find Tree Cavities",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ireneusz",
                    "lastName": "Ruczyński"
                },
                {
                    "creatorType": "author",
