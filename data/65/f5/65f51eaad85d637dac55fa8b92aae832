            "itemType": "journalArticle",
            "title": "Assessment of Fruit Bats and its Food Preferences in Mt. Apo Natural Park, Kidapawan City, North Cotabato, Philippines",
            "creators": [
                {
                    "creatorType": "author",
                    "name": "University of the Philippines Los Baños"
                },
                {
                    "creatorType": "author",
                    "firstName": "Richel",
