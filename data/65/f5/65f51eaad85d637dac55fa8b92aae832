            "itemType": "journalArticle",
            "title": "In the concrete jungle: the animalivorous bat Tonatia bidens (Phyllostomidae) recorded in the metropolis of São Paulo, Brazil",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Guilherme",
