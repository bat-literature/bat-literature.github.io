            "itemType": "journalArticle",
            "title": "Evaluation of an Integrated Framework for Biodiversity with a New Metric for Functional Dispersion",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Steven J.",
                    "lastName": "Presley"
                },
                {
                    "creatorType": "author",
