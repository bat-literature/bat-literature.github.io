            "title": "Increased Body Mass Supports Energy Compensation Hypothesis in the Breeding Female Natal Long-Fingered Bat Miniopterus Natalensis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mariëtte",
                    "lastName": "Pretorius"
                },
                {
                    "creatorType": "author",
                    "firstName": "Teresa",
                    "lastName": "Kearney"
                },
                {
                    "creatorType": "author",
