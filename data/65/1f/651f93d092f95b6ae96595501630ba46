            "title": "Modified Cave Entrances: Thermal Effect on Body Mass and Resulting Decline of Endangered Indiana Bats Myotis sodalis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Andreas R.",
                    "lastName": "Richter"
                },
