            "title": "Bats expand their vocal range by recruiting different laryngeal structures for echolocation and social communication",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jonas",
                    "lastName": "Håkansson"
                },
                {
                    "creatorType": "author",
