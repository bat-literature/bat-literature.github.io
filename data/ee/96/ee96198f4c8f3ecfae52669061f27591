            "itemType": "journalArticle",
            "title": "Taxonomy and Natural History of the Southeast Asian Fruit-Bat Genus Dyacopterus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Kristofer M.",
                    "lastName": "Helgen"
                },
                {
                    "creatorType": "author",
