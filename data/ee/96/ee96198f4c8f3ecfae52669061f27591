        "data": {
            "key": "3BG39A6E",
            "version": 56430,
            "itemType": "journalArticle",
            "title": "Female pond bats hunt in other areas than males and consume lighter prey when pregnant",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Anne-Jifke",
                    "lastName": "Haarsma"
                },
                {
                    "creatorType": "author",
                    "firstName": "Eelke",
                    "lastName": "Jongejans"
                },
                {
                    "creatorType": "author",
                    "firstName": "Elza",
                    "lastName": "Duijm"
                },
                {
                    "creatorType": "author",
                    "firstName": "Carolien",
                    "lastName": "Van Der Graaf"
                },
                {
                    "creatorType": "author",
                    "firstName": "Youri",
                    "lastName": "Lammers"
                },
                {
                    "creatorType": "author",
                    "firstName": "Milan",
                    "lastName": "Sharma"
                },
                {
                    "creatorType": "author",
                    "firstName": "Henk",
