            "itemType": "journalArticle",
            "title": "TGF-beta and IL-6 drive the production of IL-17 and IL-10 by T cells and restrain T(H)-17 cell-mediated pathology.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mandy J",
                    "lastName": "McGeachy"
                },
                {
                    "creatorType": "author",
                    "firstName": "Kristian S",
                    "lastName": "Bak-Jensen"
