            "title": "Sur7 promotes plasma membrane organization and is needed for resistance to stressful conditions and to the invasive growth and virulence of Candida albicans",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lois M.",
                    "lastName": "Douglas"
                },
                {
                    "creatorType": "author",
                    "firstName": "Hong X.",
                    "lastName": "Wang"
                },
                {
                    "creatorType": "author",
                    "firstName": "Sabine",
