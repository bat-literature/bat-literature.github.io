            "itemType": "journalArticle",
            "title": "Quantitative RNA-Seq analysis in non-model species: assessing transcriptome assemblies as a scaffold and the utility of evolutionary divergent genomic reference species.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Emily A",
                    "lastName": "Hornett"
                },
