            "itemType": "journalArticle",
            "title": "Riqueza, endemismo y conservación de los mamíferos de Colombia.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sergio",
                    "lastName": "Solari"
                },
                {
                    "creatorType": "author",
                    "firstName": "Yaneth",
