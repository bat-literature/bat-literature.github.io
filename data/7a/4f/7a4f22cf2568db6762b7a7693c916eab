            "itemType": "journalArticle",
            "title": "Coincident mass extirpation of neotropical amphibians with the emergence of the infectious fungal pathogen Batrachochytrium dendrobatidis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Tina L.",
