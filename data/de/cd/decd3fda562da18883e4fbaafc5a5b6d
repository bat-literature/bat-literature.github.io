            "itemType": "journalArticle",
            "title": "Carollia perspicillata: A Small Bat with Tremendous Translational Potential for Studies of Brain Aging and Neurodegeneration",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mark",
                    "lastName": "Stewart"
                },
                {
                    "creatorType": "author",
