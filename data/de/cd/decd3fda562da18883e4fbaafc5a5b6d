            "itemType": "journalArticle",
            "title": "Changing with the times: Seasonal environmental gradients unveil dynamic bat assemblages and vulnerability",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Helena",
                    "lastName": "Raposeira"
