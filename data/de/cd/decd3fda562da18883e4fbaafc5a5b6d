            "itemType": "journalArticle",
            "title": "Bats of the Prespa Basin in northern Greece: acoustic survey, new records and relationships to light pollution (Chiroptera)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marcel",
                    "lastName": "Uhrin"
                },
                {
                    "creatorType": "author",
