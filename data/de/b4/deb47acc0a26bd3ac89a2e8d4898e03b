            "itemType": "journalArticle",
            "title": "A novel method for targeting survey effort to identify new bat roosts using habitat suitability modelling",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lauren",
                    "lastName": "Fuller"
                },
                {
                    "creatorType": "author",
                    "firstName": "Mike",
