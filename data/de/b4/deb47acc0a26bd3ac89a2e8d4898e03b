            "itemType": "journalArticle",
            "title": "Holocene and Late Pleistocene Bat Fossils (Mammalia: Chiroptera) from Hamilton County, TN, and their Ecological Implications",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Timothy J.",
                    "lastName": "Gaudin"
                },
                {
                    "creatorType": "author",
