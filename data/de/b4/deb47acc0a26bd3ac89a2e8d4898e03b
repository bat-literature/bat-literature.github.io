        "data": {
            "key": "GYU5SVBF",
            "version": 56562,
            "itemType": "journalArticle",
            "title": "Diet in a bat assemblage in Atlantic Forest in southeastern Brazil",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ariana P.",
                    "lastName": "Gnocchi"
                },
                {
                    "creatorType": "author",
                    "firstName": "Suéli",
                    "lastName": "Huber"
