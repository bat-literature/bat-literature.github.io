            "itemType": "journalArticle",
            "title": "Acoustic deterrents influence foraging activity, flight and echolocation behaviour of free-flying bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lia R. V.",
                    "lastName": "Gilmour"
                },
                {
                    "creatorType": "author",
                    "firstName": "Marc W.",
                    "lastName": "Holderied"
                },
                {
                    "creatorType": "author",
