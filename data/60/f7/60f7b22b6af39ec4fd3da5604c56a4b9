            "title": "Hemotropic mycoplasmas in bats captured near human settlements in Nigeria",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sophia",
                    "lastName": "Di Cataldo"
                },
                {
                    "creatorType": "author",
