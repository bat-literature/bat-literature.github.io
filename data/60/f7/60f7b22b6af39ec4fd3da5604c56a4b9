            "itemType": "journalArticle",
            "title": "Roost Making in Bats—Adaptations for Excavating Active Termite Nests",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Dina K. N.",
                    "lastName": "Dechmann"
                },
                {
                    "creatorType": "author",
