            "itemType": "journalArticle",
            "title": "Implementing and Assessing the Efficacy of the North American Bat Monitoring Program",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Benjamin D.",
                    "lastName": "Neece"
                },
                {
                    "creatorType": "author",
