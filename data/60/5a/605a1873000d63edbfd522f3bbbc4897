            "itemType": "journalArticle",
            "title": "Comparison of the White-Nose Syndrome Agent Pseudogymnoascus destructans to Cave-Dwelling Relatives Suggests Reduced Saprotrophic Enzyme Activity",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Hannah T.",
                    "lastName": "Reynolds"
                },
                {
                    "creatorType": "author",
