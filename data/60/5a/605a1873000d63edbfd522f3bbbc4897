            "itemType": "journalArticle",
            "title": "How aerial insectivore bats of different sizes respond to nightly temperature shifts",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maria João",
                    "lastName": "Ramos Pereira"
                },
                {
                    "creatorType": "author",
                    "firstName": "Thais",
