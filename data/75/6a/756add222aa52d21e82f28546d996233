            "title": "Diversity of Astroviruses Circulating in Humans, Bats, and Wild Birds in Egypt",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ahmed",
                    "lastName": "El Taweel"
                },
                {
                    "creatorType": "author",
