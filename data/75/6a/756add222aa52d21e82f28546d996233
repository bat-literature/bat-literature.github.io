            "itemType": "journalArticle",
            "title": "Highly Divergent Genetic Variants of Soricid-Borne Altai Virus (Hantaviridae) in Eurasia Suggest Ancient Host-Switching Events",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Hae Ji",
                    "lastName": "Kang"
                },
                {
                    "creatorType": "author",
                    "firstName": "Se Hun",
                    "lastName": "Gu"
                },
                {
