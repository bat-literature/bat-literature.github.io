            "itemType": "journalArticle",
            "title": "Contribution of acoustic methods to the study of insectivorous bat diversity in protected areas from northern Venezuela",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "José G.",
                    "lastName": "Ochoa"
                },
                {
