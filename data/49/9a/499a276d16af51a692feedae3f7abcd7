            "title": "Internal Cave Gating for Protection of Colonies of the Endangered Gray Bat (Myotis grisescens)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Keith W.",
                    "lastName": "Martin"
                },
                {
                    "creatorType": "author",
                    "firstName": "David M.",
