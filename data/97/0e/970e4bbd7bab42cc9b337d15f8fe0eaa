            "title": "Impact of a Century of Climate Change on Small-Mammal Communities in Yosemite National Park, USA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Craig",
                    "lastName": "Moritz"
                },
                {
                    "creatorType": "author",
