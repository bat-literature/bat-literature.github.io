            "title": "Population size and the risk of local extinction: empirical evidence from rare plants",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Diethart",
                    "lastName": "Matthies"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ingo",
