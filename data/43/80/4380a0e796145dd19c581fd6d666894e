            "title": "Bats of the Tunisian Desert: Preliminary Data Using Acoustic Identification and First Record of Taphozous nudiventris in the Country",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ridha",
                    "lastName": "Dalhoumi"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ridha",
                    "lastName": "El Mokni"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ridha",
