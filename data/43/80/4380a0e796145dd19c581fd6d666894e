            "itemType": "journalArticle",
            "title": "Responses of insectivorous bats to climate change in Nepal",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D. R.",
                    "lastName": "Dahal"
                },
                {
                    "creatorType": "author",
