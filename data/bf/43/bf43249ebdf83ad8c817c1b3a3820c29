            "title": "The Antioxidant Status of Three Neotropical Bat Species with Different Feeding Habits",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Renata M.",
                    "lastName": "Pereira Freitas"
                },
                {
                    "creatorType": "author",
