        "data": {
            "key": "VSLMUELY",
            "version": 35016,
            "itemType": "journalArticle",
            "title": "Seven-year impact of white-nose syndrome on tri-colored bat (Perimyotis subflavus) populations in Georgia, USA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "S",
                    "lastName": "Perea"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ja",
                    "lastName": "Yearout"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ea",
                    "lastName": "Ferrall"
