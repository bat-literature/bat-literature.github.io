            "title": "Bat winter foraging habitat use in working forests: a multispecies spatial occupancy approach",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "S.",
                    "lastName": "Perea"
                },
                {
                    "creatorType": "author",
