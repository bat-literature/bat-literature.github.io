        "data": {
            "key": "J4F8F3RV",
            "version": 35016,
            "itemType": "journalArticle",
            "title": "A decade of hibernating bat communities along the periphery of a region of white‐nose syndrome",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Santiago",
                    "lastName": "Perea"
                },
                {
                    "creatorType": "author",
                    "firstName": "Emily A.",
                    "lastName": "Ferrall"
                },
                {
                    "creatorType": "author",
                    "firstName": "Katrina M.",
                    "lastName": "Morris"
                },
                {
                    "creatorType": "author",
                    "firstName": "Pete E.",
