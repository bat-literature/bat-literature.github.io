            "itemType": "journalArticle",
            "title": "Morphological, olfactory, and vocal development in big brown bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Heather W.",
                    "lastName": "Mayberry"
                },
                {
                    "creatorType": "author",
                    "firstName": "Paul A.",
                    "lastName": "Faure"
