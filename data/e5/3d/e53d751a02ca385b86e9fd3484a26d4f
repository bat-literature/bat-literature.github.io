        "data": {
            "key": "YG7FT6MV",
            "version": 73112,
            "itemType": "journalArticle",
            "title": "Feasting, fasting and freezing: energetic effects of meal size and temperature on torpor expression by little brown bats Myotislucifugus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "A. L.",
                    "lastName": "Matheson"
                },
                {
                    "creatorType": "author",
