            "itemType": "journalArticle",
            "title": "First report of Litmosa spp. (Nematoda : Filarioidea) from Malagasy bats; review of the genus and relationships between species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "C.",
                    "lastName": "Martin"
                },
                {
