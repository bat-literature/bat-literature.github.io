            "itemType": "journalArticle",
            "title": "Sexual dimorphism in bat wing morphology — variation among foraging styles",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D.G.",
                    "lastName": "Maucieri"
                },
