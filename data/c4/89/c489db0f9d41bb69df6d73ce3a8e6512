            "itemType": "journalArticle",
            "title": "A New Species of Horseshoe Bat (Chiroptera: Rhinolophidae) from Mount Namuli, Mozambique",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Michael",
                    "lastName": "Curran"
