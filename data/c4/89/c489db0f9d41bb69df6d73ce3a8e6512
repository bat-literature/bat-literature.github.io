            "title": "Distribution, Abundance and Roosts of the Fruit Bat Artibeus fraterculus (Chiroptera: Phyllostomidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "C. Miguel",
                    "lastName": "Pinto"
                },
                {
                    "creatorType": "author",
