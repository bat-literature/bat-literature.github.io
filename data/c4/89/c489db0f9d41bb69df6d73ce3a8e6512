            "title": "Noctilio albiventris (Noctilionidae), a Potential Seed Disperser in Disturbed Tropical Dry Forest Habitats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Carla I.",
                    "lastName": "Aranguren"
                },
