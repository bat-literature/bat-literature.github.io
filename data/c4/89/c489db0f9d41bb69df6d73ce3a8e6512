            "itemType": "journalArticle",
            "title": "Divergent Microclimates in Artificial and Natural Roosts of the Large-Footed Myotis (Myotis macropus)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Susan",
                    "lastName": "Campbell"
                },
                {
                    "creatorType": "author",
