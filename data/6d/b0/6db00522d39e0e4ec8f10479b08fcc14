            "title": "Effects of wastewater treatment plant effluent on bat foraging ecology in an urban stream system",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "M.C.",
                    "lastName": "Kalcounis-Rueppell"
                },
                {
