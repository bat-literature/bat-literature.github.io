            "title": "A multi-taxa assessment of nestedness patterns across a multiple-use Amazonian forest landscape",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Julio",
                    "lastName": "Louzada"
                },
                {
                    "creatorType": "author",
