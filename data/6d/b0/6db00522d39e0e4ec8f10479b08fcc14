            "title": "Recurring fires in Mediterranean habitats and their impact on bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Adrià",
                    "lastName": "López-Baucells"
                },
                {
                    "creatorType": "author",
                    "firstName": "Carles",
                    "lastName": "Flaquer"
                },
