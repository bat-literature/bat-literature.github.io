            "itemType": "journalArticle",
            "title": "Middle East respiratory syndrome coronavirus (MERS-CoV): animal to human interaction",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ali S.",
                    "lastName": "Omrani"
                },
