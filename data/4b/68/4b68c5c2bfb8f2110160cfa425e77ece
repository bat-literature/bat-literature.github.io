            "itemType": "journalArticle",
            "title": "Species protection, the changing informal economy, and the politics of access to the bushmeat trade in the Democratic Republic of Congo",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Emmanuel",
                    "lastName": "De Merode"
