            "itemType": "journalArticle",
            "title": "Super-Resolution Fluorescence Imaging Reveals That Serine Incorporator Protein 5 Inhibits Human Immunodeficiency Virus Fusion by Disrupting Envelope Glycoprotein Clusters",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Yen-Cheng",
                    "lastName": "Chen"
                },
                {
                    "creatorType": "author",
