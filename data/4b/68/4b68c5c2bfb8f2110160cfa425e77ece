            "title": "Social Network Predicts Exposure to Respiratory Infection in a Wild Chimpanzee Group",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Aaron A.",
                    "lastName": "Sandel"
                },
                {
                    "creatorType": "author",
                    "firstName": "Julie",
                    "lastName": "Rushmore"
                },
                {
                    "creatorType": "author",
