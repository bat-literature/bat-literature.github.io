            "itemType": "journalArticle",
            "title": "High duty cycle moth sounds jam bat echolocation: bats counter with compensatory changes in buzz duration",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Yohami",
                    "lastName": "Fernández"
                },
                {
                    "creatorType": "author",
