            "title": "Can Bats Serve as Reservoirs for Arboviruses?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Anna C.",
                    "lastName": "Fagre"
                },
                {
                    "creatorType": "author",
                    "firstName": "Rebekah C.",
                    "lastName": "Kading"
