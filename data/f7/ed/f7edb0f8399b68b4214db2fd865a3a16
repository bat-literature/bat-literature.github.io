        "data": {
            "key": "TKCVPYEY",
            "version": 56516,
            "itemType": "journalArticle",
            "title": "Effects of habitat age and disturbance intensity on the biodiversity of three trophic levels in Central Kenya",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Michael",
                    "lastName": "Eisenring"
                },
                {
                    "creatorType": "author",
