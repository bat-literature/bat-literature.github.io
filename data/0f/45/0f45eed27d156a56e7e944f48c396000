            "itemType": "journalArticle",
            "title": "On the Presence of Pipistrelle Bats (Pipistrellus and Hypsugo; Chiroptera: Vespertilionidae) in Sardinia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Michael",
                    "lastName": "Veith"
                },
                {
                    "creatorType": "author",
                    "firstName": "Mauro",
                    "lastName": "Mucedda"
                },
                {
                    "creatorType": "author",
