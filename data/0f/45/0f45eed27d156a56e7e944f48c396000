            "itemType": "journalArticle",
            "title": "Parasitism of ectoparasitic flies on bats in the northern Brazilian cerrado",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ciro",
                    "lastName": "Santos"
                },
                {
                    "creatorType": "author",
