        "data": {
            "key": "URGQZ5UR",
            "version": 54424,
            "itemType": "journalArticle",
            "title": "Metales pesados en especies de murciélagos (quiróptera) asociados a una finca bajo manejo silvopastoril en el departamento de Córdoba, Colombia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Javier",
                    "lastName": "Racero-Casarrubia"
                },
                {
                    "creatorType": "author",
