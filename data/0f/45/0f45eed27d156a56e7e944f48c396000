        "data": {
            "key": "H3RDB2IN",
            "version": 54423,
            "itemType": "journalArticle",
            "title": "Se describe una nueva especie de murciélago del género Carollia Gray, 1838 (Chiroptera: Phyllostomidae) de Colombia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Javier",
                    "lastName": "Muñoz"
