            "itemType": "journalArticle",
            "title": "Genetic Diversity of Northeastern Palaearctic Bats as Revealed by DNA Barcodes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sergei V.",
                    "lastName": "Kruskop"
                },
                {
                    "creatorType": "author",
                    "firstName": "Alex V.",
                    "lastName": "Borisenko"
                },
                {
                    "creatorType": "author",
                    "firstName": "Natalia V.",
                    "lastName": "Ivanova"
                },
                {
                    "creatorType": "author",
