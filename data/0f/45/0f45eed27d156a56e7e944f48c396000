            "title": "Reproductive Seasonality of Fruit-Eating Bats in Northwestern Yucatan, Mexico",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Salvador",
                    "lastName": "Montiel"
                },
                {
                    "creatorType": "author",
