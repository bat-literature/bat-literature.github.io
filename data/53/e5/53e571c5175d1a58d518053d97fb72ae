            "title": "Mammal species richness and biogeographic structure at the southern boundaries of the Nearctic region",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Tania",
                    "lastName": "Escalante"
                },
                {
                    "creatorType": "author",
                    "firstName": "Gerardo",
