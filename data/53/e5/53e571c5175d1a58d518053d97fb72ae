            "itemType": "journalArticle",
            "title": "The contribution of Edouard-Louis Trouessart to mammalogy",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christiane",
                    "lastName": "Denys"
                },
                {
                    "creatorType": "author",
