            "title": "Duration selectivity organization in the inferior colliculus of the big brown bat, Eptesicus fuscus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Philip H.-S.",
                    "lastName": "Jen"
                },
                {
                    "creatorType": "author",
                    "firstName": "Chung Hsin",
                    "lastName": "Wu"
