            "itemType": "journalArticle",
            "title": "DETECTION OF PREY IN A CLUTTERED ENVIRONMENT BY THE NORTHERN BAT EPTESICUS NILSSONII",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marianne Egebjerg",
