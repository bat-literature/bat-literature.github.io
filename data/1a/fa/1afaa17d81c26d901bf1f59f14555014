        "data": {
            "key": "Y5MXQKXS",
            "version": 56846,
            "itemType": "journalArticle",
            "title": "Control region variability of the mitochondrial DNA of Pipistrellus nathusii (Chiroptera, Vespertilionidae): First results of a population genetic study",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Tomasz",
