            "itemType": "journalArticle",
            "title": "Prey Consumed by Eight Species of Insectivorous Bats from Southern Illinois",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "George A.",
                    "lastName": "Feldhamer"
                },
