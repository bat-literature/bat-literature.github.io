            "title": "Effects of hedgerows on bats and bush crickets at different spatial scales",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Aurélie",
                    "lastName": "Lacoeuilhe"
                },
                {
                    "creatorType": "author",
