            "itemType": "journalArticle",
            "title": "Male Chemical Signalling to Recruit Females in the Greater Short-Nosed Fruit Bat Cynopterus sphinx",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Anbalagan",
                    "lastName": "Rathinakumar"
                },
                {
                    "creatorType": "author",
