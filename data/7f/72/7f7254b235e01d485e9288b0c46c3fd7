            "itemType": "journalArticle",
            "title": "Habitat Selections of Himalayan Insectivorous Bats in Forest-Dominated Landscapes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Tshering",
                    "lastName": "Dendup"
                },
                {
                    "creatorType": "author",
                    "firstName": "Pipat",
