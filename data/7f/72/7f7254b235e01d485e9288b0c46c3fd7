            "itemType": "journalArticle",
            "title": "Hidden Afrotropical Bat Diversity in Nigeria: Ten New Country Records from a Biodiversity Hotspot",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Iroro",
                    "lastName": "Tanshi"
                },
                {
