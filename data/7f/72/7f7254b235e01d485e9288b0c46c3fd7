            "itemType": "journalArticle",
            "title": "Towards navigating the Minotaur’s labyrinth: cryptic diversity and taxonomic revision within the speciose genus Hipposideros (Hipposideridae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nicole M.",
                    "lastName": "Foley"
                },
                {
                    "creatorType": "author",
                    "firstName": "Steven M.",
                    "lastName": "Goodman"
                },
                {
                    "creatorType": "author",
