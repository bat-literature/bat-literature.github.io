            "itemType": "journalArticle",
            "title": "Habitat Use of Constant Frequency Echolocating Bats in North-West Madagascar with Acoustic Evidence for a Possible New Species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel",
