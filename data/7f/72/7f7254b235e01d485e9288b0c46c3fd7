            "itemType": "journalArticle",
            "title": "Frugivory and the effects of ingestion by bats on the seed germination of three pioneering plants",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maria C.",
                    "lastName": "De Carvalho-Ricardo"
                },
                {
                    "creatorType": "author",
