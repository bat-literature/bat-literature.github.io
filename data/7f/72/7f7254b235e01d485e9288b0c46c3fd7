            "title": "Bats of Paraguay: Specimen Data Reveal Ecoregional Preferences and Diverse Seasonal Patterns",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Robert D.",
                    "lastName": "Owen"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jeremy V.",
                    "lastName": "Camp"
