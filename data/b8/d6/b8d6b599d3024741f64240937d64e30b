            "itemType": "journalArticle",
            "title": "Variable Variation: Annual and Seasonal Changes in Offspring Sex Ratio in a Bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Robert M. R.",
                    "lastName": "Barclay"
                },
