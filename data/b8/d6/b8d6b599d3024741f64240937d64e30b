        "data": {
            "key": "6Y2SKSXG",
            "version": 77870,
            "itemType": "journalArticle",
            "title": "A Large‐Scale Mitigation Experiment to Reduce Bat Fatalities at Wind Energy Facilities",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Erin F.",
                    "lastName": "Baerwald"
                },
                {
                    "creatorType": "author",
