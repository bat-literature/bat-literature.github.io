            "title": "Altering turbine speed reduces bat mortality at wind‐energy facilities",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Edward B",
                    "lastName": "Arnett"
                },
                {
                    "creatorType": "author",
                    "firstName": "Manuela Mp",
