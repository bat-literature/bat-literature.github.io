            "title": "Do you hear what I hear? Implications of detector selection for acoustic monitoring of bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Amanda M.",
                    "lastName": "Adams"
                },
                {
                    "creatorType": "author",
