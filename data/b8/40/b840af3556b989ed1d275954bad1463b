            "itemType": "journalArticle",
            "title": "Temporal Patterns of Individual and Group Foraging Behaviour in the Short- Nosed Fruit Bat, Cynopterus sphinx, in South India",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "V.",
                    "lastName": "Elangovan"
                },
                {
                    "creatorType": "author",
