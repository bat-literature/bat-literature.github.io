            "title": "Subtle changes in elevation shift bat‐assemblage structure in Central Amazonia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ubirajara Dutra",
                    "lastName": "Capaverde"
                },
                {
                    "creatorType": "author",
                    "firstName": "Lucas Gabriel Do Amaral",
                    "lastName": "Pereira"
                },
                {
                    "creatorType": "author",
                    "firstName": "Valéria Da Cunha",
