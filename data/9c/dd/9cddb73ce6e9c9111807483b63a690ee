            "title": "Impacto en los quirópteros de dos parques eólicos en el Valle del Ebro (Zaragoza) y propuesta de mitigación",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Álvaro",
                    "lastName": "Camiña"
                },
                {
                    "creatorType": "author",
