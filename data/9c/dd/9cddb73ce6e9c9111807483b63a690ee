        "data": {
            "key": "7KYZKVZW",
            "version": 55230,
            "itemType": "journalArticle",
            "title": "Hunting, disturbance and roost persistence of bats in caves at Ankarana, northern Madagascar",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Scott G.",
                    "lastName": "Cardiff"
                },
                {
                    "creatorType": "author",
                    "firstName": "Fanja H.",
