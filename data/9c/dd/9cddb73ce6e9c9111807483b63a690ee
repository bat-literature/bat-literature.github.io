            "title": "Morphological and Ecological Correlates of Coexistence in Malaysian Fruit Bats (Chiroptera: Pteropodidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Polly",
                    "lastName": "Campbell"
                },
                {
                    "creatorType": "author",
