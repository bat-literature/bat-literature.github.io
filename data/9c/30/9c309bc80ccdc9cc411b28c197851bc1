            "itemType": "journalArticle",
            "title": "Frequent Arousals from Winter Torpor in Rafinesque’s Big-Eared Bat (Corynorhinus rafinesquii)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Joseph S.",
                    "lastName": "Johnson"
                },
                {
                    "creatorType": "author",
                    "firstName": "Michael J.",
