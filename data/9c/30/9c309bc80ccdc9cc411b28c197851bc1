            "itemType": "journalArticle",
            "title": "Effects of bat white-nose syndrome on hibernation and swarming aggregations of bats in Ontario",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lauren A.",
                    "lastName": "Hooton"
