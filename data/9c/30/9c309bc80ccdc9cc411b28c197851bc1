            "title": "Hibernation energetics of free-ranging little brown bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Kristin A.",
                    "lastName": "Jonasson"
                },
                {
                    "creatorType": "author",
                    "firstName": "Craig K. R.",
                    "lastName": "Willis"
