            "itemType": "journalArticle",
            "title": "Foraging activity and food resource use of Brazilian free-tailed bats, Tadarida brasiliensis (Molossidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ya-Fu",
