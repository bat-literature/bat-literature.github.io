        "data": {
            "key": "LV8666QF",
            "version": 78462,
            "itemType": "journalArticle",
            "title": "Weather‐driven dynamics in a dual‐migrant system: moths and bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jennifer J.",
                    "lastName": "Krauel"
                },
