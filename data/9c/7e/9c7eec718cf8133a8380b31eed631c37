        "data": {
            "key": "SNE8DA7X",
            "version": 83988,
            "itemType": "journalArticle",
            "title": "Carpe noctem: the importance of bats as bioindicators",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "G",
                    "lastName": "Jones"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ds",
                    "lastName": "Jacobs"
                },
                {
                    "creatorType": "author",
