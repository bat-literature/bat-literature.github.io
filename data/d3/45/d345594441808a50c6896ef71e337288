            "itemType": "journalArticle",
            "title": "Temperatures Beneath Bark of Dead Trees used as Roosts by Myotis volans in Forests of the Pacific Northwest, USA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Michael J.",
                    "lastName": "Lacki"
                },
                {
                    "creatorType": "author",
