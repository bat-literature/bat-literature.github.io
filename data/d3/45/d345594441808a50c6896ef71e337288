            "title": "Species Composition of Bats in Brazilian Restingas: Testing Environmental Versus Geographical Hypotheses for Community Composition",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Thiago B.",
                    "lastName": "Vieira"
                },
