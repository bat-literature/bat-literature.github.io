            "version": 74572,
            "itemType": "journalArticle",
            "title": "The Implications of Sympatry in the Spectacled and Grey Headed Flying-Fox, Pteropus conspicillatus and P. poliocephalus (Chiroptera: Pteropodidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jennifer G.",
                    "lastName": "Parsons"
                },
                {
