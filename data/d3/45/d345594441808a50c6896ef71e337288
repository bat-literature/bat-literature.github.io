            "itemType": "journalArticle",
            "title": "The Distinctive Structure of Social Calls by Hanák's Dwarf Bat Pipistrellus hanaki",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Panagiotis",
                    "lastName": "Georgiakakis"
                },
