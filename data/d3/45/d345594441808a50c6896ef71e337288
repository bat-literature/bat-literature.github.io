            "title": "Morphological and Echolocation Call Variation in Malagasy Trident Bats, Triaenops Dobson, 1871 (Chiroptera: Hipposideridae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Beza",
                    "lastName": "Ramasindrazana"
                },
                {
