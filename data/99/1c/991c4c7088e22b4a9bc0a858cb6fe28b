        "data": {
            "key": "E567NJB9",
            "version": 79812,
            "itemType": "journalArticle",
            "title": "Human disturbance alters endocrine and immune responses in the Galapagos marine iguana (Amblyrhynchus cristatus)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Susannah S.",
                    "lastName": "French"
                },
                {
                    "creatorType": "author",
                    "firstName": "Dale F.",
                    "lastName": "DeNardo"
                },
                {
                    "creatorType": "author",
                    "firstName": "Timothy J.",
