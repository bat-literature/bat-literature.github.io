            "title": "Hybrid Zones, Genetic Isolation, and Systematics of Pocket Gophers (Genus <i>Geomys</i> ) in Nebraska",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Hugh H.",
                    "lastName": "Genoways"
                },
                {
