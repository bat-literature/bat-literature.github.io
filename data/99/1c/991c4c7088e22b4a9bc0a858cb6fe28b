        "data": {
            "key": "9PT3WNJP",
            "version": 79994,
            "itemType": "journalArticle",
            "title": "Further characterization of the pituitary‐adrenocortical responses to stress in Chiroptera",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Eric P.",
                    "lastName": "Widmaier"
                },
                {
                    "creatorType": "author",
                    "firstName": "Tara L.",
