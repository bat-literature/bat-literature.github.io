            "itemType": "journalArticle",
            "title": "Evolutionary Arms Race between Virus and Host Drives Genetic Diversity in Bat Severe Acute Respiratory Syndrome-Related Coronavirus Spike Genes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Hua",
                    "lastName": "Guo"
                },
                {
                    "creatorType": "author",
                    "firstName": "Bing-Jie",
