            "title": "Scientific Collaborations: How Do We Measure the Return on Relationships?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jeanne M.",
                    "lastName": "Fair"
                },
                {
                    "creatorType": "author",
