            "itemType": "journalArticle",
            "title": "A New Species of Forest Mouse, Genus Apomys (Mammalia: Rodentia: Muridae), from Camiguin Island, Philippines",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lawrence R.",
