            "itemType": "journalArticle",
            "title": "Trophic interaction modifications: an empirical and theoretical framework",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "J. Christopher D.",
                    "lastName": "Terry"
                },
                {
                    "creatorType": "author",
                    "firstName": "Rebecca J.",
