            "itemType": "journalArticle",
            "title": "Rabies in a postpandemic world: resilient reservoirs, redoubtable riposte, recurrent roadblocks, and resolute recidivism",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Charles E.",
                    "lastName": "Rupprecht"
                },
                {
                    "creatorType": "author",
                    "firstName": "Philip P.",
