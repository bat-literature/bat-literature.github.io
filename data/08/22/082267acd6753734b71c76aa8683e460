            "itemType": "journalArticle",
            "title": "Evolution of physiological performance capacities and environmental adaptation: insights from high-elevation deer mice (Peromyscus maniculatus)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jay F",
                    "lastName": "Storz"
                },
                {
                    "creatorType": "author",
