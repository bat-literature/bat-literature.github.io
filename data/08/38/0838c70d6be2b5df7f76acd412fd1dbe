            "itemType": "journalArticle",
            "title": "Modeling the Potential Distribution Range of Barbastella walteri (Barbastella: Chiroptera, Vespertilionidae) in the Central Asian Region Based on Bioclimatic Data",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D. G.",
                    "lastName": "Smirnov"
                },
                {
                    "creatorType": "author",
