            "itemType": "journalArticle",
            "title": "Adverse effects of artificial illumination on bat drinking activity",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D.",
                    "lastName": "Russo"
                },
                {
                    "creatorType": "author",
                    "firstName": "L.",
