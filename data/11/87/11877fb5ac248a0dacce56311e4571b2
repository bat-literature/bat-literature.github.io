            "itemType": "journalArticle",
            "title": "Altitudinal distribution and anthropogenic influence on small mammal assemblages on Mount Kupe, SW Cameroon.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christiane",
                    "lastName": "Denys"
                },
                {
                    "creatorType": "author",
                    "firstName": "Alain Didier",
