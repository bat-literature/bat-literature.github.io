            "title": "Digestive capacity predicts diet diversity in Neotropical frugivorous bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Romeo A.",
                    "lastName": "Saldaña‐Vázquez"
                },
                {
                    "creatorType": "author",
                    "firstName": "Eduardo",
                    "lastName": "Ruiz‐Sanchez"
                },
                {
                    "creatorType": "author",
                    "firstName": "Leonel",
