            "title": "Phylogenetic signal, feeding behaviour and brain volume in Neotropical bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D.",
                    "lastName": "Rojas"
                },
                {
                    "creatorType": "author",
