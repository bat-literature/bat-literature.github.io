            "itemType": "journalArticle",
            "title": "Guild-specific response of bats to motion-triggered LED lighting of bicycle trails",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Olga",
                    "lastName": "Heim"
                },
                {
