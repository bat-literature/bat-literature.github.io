            "itemType": "journalArticle",
            "title": "Patterns of survival and roost switching in an African insectivorous bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "A.",
                    "lastName": "Monadjem"
                },
                {
                    "creatorType": "author",
