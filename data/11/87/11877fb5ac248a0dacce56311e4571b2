            "title": "Within-guild dietary discrimination from 3-D textural analysis of tooth microwear in insectivorous mammals",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "M. A.",
                    "lastName": "Purnell"
                },
                {
                    "creatorType": "author",
                    "firstName": "N.",
                    "lastName": "Crumpton"
                },
                {
                    "creatorType": "author",
                    "firstName": "P. G.",
