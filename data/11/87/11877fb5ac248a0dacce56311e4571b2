            "title": "Diversifying selection and climatic effects on major histocompatibility complex class II gene diversity in the greater horseshoe bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Xiaolin",
                    "lastName": "Li"
                },
                {
                    "creatorType": "author",
                    "firstName": "Tong",
                    "lastName": "Liu"
                },
                {
                    "creatorType": "author",
                    "firstName": "Aoqiang",
                    "lastName": "Li"
                },
                {
