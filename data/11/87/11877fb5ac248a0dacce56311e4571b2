            "title": "Bats like vintage: managing exotic eucalypt plantations for bat conservation in a Mediterranean landscape",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "J.",
                    "lastName": "Cruz"
                },
                {
                    "creatorType": "author",
