            "title": "BAT – Biodiversity Assessment Tools, an R package for the measurement and estimation of alpha and beta taxon, phylogenetic and functional diversity",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pedro",
                    "lastName": "Cardoso"
                },
                {
