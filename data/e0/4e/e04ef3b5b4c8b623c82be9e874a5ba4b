            "itemType": "journalArticle",
            "title": "Environmental and spatial drivers of taxonomic, functional, and phylogenetic characteristics of bat communities in human-modified landscapes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Laura M.",
                    "lastName": "Cisneros"
                },
                {
                    "creatorType": "author",
