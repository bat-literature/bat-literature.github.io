            "itemType": "journalArticle",
            "title": "Morphometric variation in Periglischrus torrealbai (Acari: Spinturnicidae) on three species of host bats (Chiroptera: Phyllostomidae) with a new record of host species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Juliana Cardoso",
                    "lastName": "De Almeida"
                },
                {
                    "creatorType": "author",
