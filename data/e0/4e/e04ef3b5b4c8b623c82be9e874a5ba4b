            "itemType": "journalArticle",
            "title": "Captura de Desmodus rotundus em regiões de mata e manguezais do Estado do Maranhão: um estudo longitudinal",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Roberto C.N.",
                    "lastName": "Arruda"
                },
                {
                    "creatorType": "author",
