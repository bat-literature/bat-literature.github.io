            "title": "Trypanosomatid Infections among Vertebrates of Chile: A Systematic Review",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Juana P.",
                    "lastName": "Correa"
                },
                {
                    "creatorType": "author",
                    "firstName": "Antonella",
