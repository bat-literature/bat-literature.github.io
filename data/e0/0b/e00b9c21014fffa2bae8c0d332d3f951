            "itemType": "journalArticle",
            "title": "Los murciélagos (Mammalia: Chiroptera) de la Región de Murcia (SE España): distribución y estado de conservación",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Fulgencio",
