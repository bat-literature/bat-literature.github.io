            "title": "Serological survey of lyssaviruses in synanthropic bats and human exposure to bats in Slovakia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ľuboš",
                    "lastName": "Korytár"
                },
                {
                    "creatorType": "author",
