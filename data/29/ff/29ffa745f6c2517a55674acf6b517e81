            "itemType": "journalArticle",
            "title": "Local Demand Drives a Bushmeat Industry in a Philippine Forest Preserve",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Brett R.",
                    "lastName": "Scheffers"
                },
                {
                    "creatorType": "author",
