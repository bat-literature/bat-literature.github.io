            "itemType": "journalArticle",
            "title": "Using Google Earth to Improve the Management of Threatened Limestone Karst Ecosystems in Peninsular Malaysia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Thor-Seng",
                    "lastName": "Liew"
