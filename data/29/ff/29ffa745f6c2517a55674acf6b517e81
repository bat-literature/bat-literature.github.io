            "itemType": "journalArticle",
            "title": "Ecology of Rabies Virus Exposure in Colonies of Brazilian Free-Tailed Bats (Tadarida brasiliensis) at Natural and Man-Made Roosts in Texas",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Amy S.",
                    "lastName": "Turmelle"
                },
                {
                    "creatorType": "author",
