            "title": "Stealth echolocation in aerial hawking bats reflects a substrate gleaning ancestry",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel",
                    "lastName": "Lewanzik"
                },
                {
                    "creatorType": "author",
