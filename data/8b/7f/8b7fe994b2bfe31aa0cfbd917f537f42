            "itemType": "journalArticle",
            "title": "New chiropterans from the middle Eocene of Shanghuang (Jiangsu Province, Coastal China): new insight into the dawn horseshoe bats (Rhinolophidae) in Asia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Anthony",
                    "lastName": "Ravel"
                },
                {
                    "creatorType": "author",
