            "itemType": "journalArticle",
            "title": "Non-kin adoption in the common vampire bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Imran",
                    "lastName": "Razik"
                },
                {
                    "creatorType": "author",
