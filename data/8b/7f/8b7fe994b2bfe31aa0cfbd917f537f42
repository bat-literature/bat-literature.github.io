            "itemType": "journalArticle",
            "title": "New record of Rhinolophus chiewkweeae (Chiroptera: Rhinolophidae) from the east coast of Peninsular Malaysia with new information on their echolocation calls, genetics and their taxonomy.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Muhd Amsyari",
                    "lastName": "Morni"
                },
                {
                    "creatorType": "author",
                    "firstName": "Isham",
                    "lastName": "Azhar"
                },
                {
                    "creatorType": "author",
                    "firstName": "Azuan",
                    "lastName": "Roslan"
                },
                {
                    "creatorType": "author",
