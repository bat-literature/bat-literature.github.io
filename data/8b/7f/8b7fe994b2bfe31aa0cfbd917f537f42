            "itemType": "journalArticle",
            "title": "Nursery Roosts Used by Barbastelle Bats, Barbastella barbastellus (Schreber, 1774) (Chiroptera: Vespertilionidae) in European Lowland Mixed Forest Transformed by Spruce Bark Beetle, Ips typographus (Linnaeus, 1758) (Coleoptera: Curculionidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alek",
                    "lastName": "Rachwald"
                },
                {
                    "creatorType": "author",
                    "firstName": "Grzegorz",
                    "lastName": "Apoznański"
                },
                {
