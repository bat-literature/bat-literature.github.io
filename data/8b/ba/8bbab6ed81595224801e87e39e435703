            "itemType": "journalArticle",
            "title": "Mineral and Nitrogen Concentrations in Feces of Some Neotropical Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "E. H.",
                    "lastName": "Studier"
                },
                {
                    "creatorType": "author",
                    "firstName": "S. H.",
