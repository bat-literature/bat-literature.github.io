            "itemType": "journalArticle",
            "title": "Mamíferos de cuatro áreas con diferente grado de alteración en el sureste de México",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Cornelio",
                    "lastName": "Sánchez Hernández"
                },
                {
                    "creatorType": "author",
