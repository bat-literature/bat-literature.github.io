            "title": "Molecular adaptation and convergent evolution of frugivory in Old World and neotropical fruit bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Kai",
                    "lastName": "Wang"
                },
                {
                    "creatorType": "author",
