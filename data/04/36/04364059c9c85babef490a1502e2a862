            "itemType": "journalArticle",
            "title": "Pollen digestion by nectarivorous and frugivorous Antillean bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "C.A.",
                    "lastName": "Mancina"
                },
                {
                    "creatorType": "author",
