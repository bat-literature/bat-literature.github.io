            "itemType": "journalArticle",
            "title": "Signatures of echolocation and dietary ecology in the adaptive evolution of skull shape in bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jessica H.",
                    "lastName": "Arbour"
                },
                {
                    "creatorType": "author",
