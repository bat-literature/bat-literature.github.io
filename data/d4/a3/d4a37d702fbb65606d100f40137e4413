            "itemType": "journalArticle",
            "title": "Do Energetic Challenges Mimicking Missed Foraging Encourage Torpor Use by a Neotropical Bat?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Zenon J.",
