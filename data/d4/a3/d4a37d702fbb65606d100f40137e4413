            "itemType": "journalArticle",
            "title": "COMPARATIVE COMMUNITY ECOLOGY OF BATS FROM EASTERN PARAGUAY: TAXONOMIC, ECOLOGICAL, AND BIOGEOGRAPHIC PERSPECTIVES",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Richard D.",
