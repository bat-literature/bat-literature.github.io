            "itemType": "journalArticle",
            "title": "Hair, there and everywhere: A comparison of bat wing sensory hair distribution",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Andrea D.",
                    "lastName": "Rummel"
                },
                {
                    "creatorType": "author",
