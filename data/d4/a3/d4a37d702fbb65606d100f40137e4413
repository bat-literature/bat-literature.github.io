            "itemType": "journalArticle",
            "title": "Latitudinal gradients of genus richness and endemism and the diversification of New World bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Héctor T.",
                    "lastName": "Arita"
