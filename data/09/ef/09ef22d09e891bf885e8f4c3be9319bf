            "itemType": "journalArticle",
            "title": "Estimation of spatiotemporal trends in bat abundance from mortality data collected at wind turbines",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christina M.",
                    "lastName": "Davy"
                },
                {
                    "creatorType": "author",
