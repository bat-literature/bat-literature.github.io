            "itemType": "journalArticle",
            "title": "Differences in foraging behaviour between Pipistrellus pipistrellus(Schreber, 1774) and Pipistrelluspygmaeus (Leach, 1825)",
            "creators": [
                {
                    "creatorType": "author",
