            "itemType": "journalArticle",
            "title": "Comparative cytogenetics of two species of Dermanura (Chiroptera, Phyllostomidae) in Midwestern Brazil",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ricardo Firmino",
                    "lastName": "De Sousa"
                },
                {
                    "creatorType": "author",
