            "itemType": "journalArticle",
            "title": "The use of leukocyte profiles to measure stress in vertebrates: A review for ecologists",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "A. K.",
                    "lastName": "Davis"
                },
                {
                    "creatorType": "author",
