            "itemType": "journalArticle",
            "title": "Occurrence and infestation rates of Streblidae (Diptera, Hippoboscoidea) on bats (Mammalia, Chiroptera) in a semideciduous seasonal forest fragment in western Paraná, Brazil",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mateus R.",
                    "lastName": "Ribas"
                },
                {
                    "creatorType": "author",
