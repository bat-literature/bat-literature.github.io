            "itemType": "journalArticle",
            "title": "Phylogenetic relationships among horseshoe bats within the Rhinolophus ferrumequinum group (Mammalia, Chiroptera)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marek",
                    "lastName": "Uvizl"
                },
                {
                    "creatorType": "author",
                    "firstName": "Zuzana",
