        "data": {
            "key": "M6BBL9NX",
            "version": 58608,
            "itemType": "journalArticle",
            "title": "Phylogenetic position of the giant house bat Scotophilus nigrita (Chiroptera, Vespertilionidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Peter",
                    "lastName": "Vallo"
