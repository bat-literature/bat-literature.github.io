            "itemType": "journalArticle",
            "title": "On the density-dependence of seed predation in Dipteryx micrantha , a bat-dispersed rain forest tree",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Hanna",
                    "lastName": "Tuomisto"
                },
                {
                    "creatorType": "author",
