            "itemType": "journalArticle",
            "title": "Ontogenetic and anatomic variation in mineralization of the wing skeleton of the Mexican free‐tailed bat, Tadarida brasiliensis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Helen M.",
