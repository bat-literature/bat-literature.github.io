            "itemType": "journalArticle",
            "title": "Mammal assemblage composition predicts global patterns in emerging infectious disease risk",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Yingying X. G.",
                    "lastName": "Wang"
                },
                {
