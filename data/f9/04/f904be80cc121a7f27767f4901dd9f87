            "itemType": "journalArticle",
            "title": "Partial molecular characterization of alphaherpesviruses isolated from tropical bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "R.",
                    "lastName": "Razafindratsimandresy"
                },
