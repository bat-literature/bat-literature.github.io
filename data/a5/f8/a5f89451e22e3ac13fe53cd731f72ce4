            "title": "Evaluating and Ranking the Vulnerability of Global Marine Ecosystems to Anthropogenic Threats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Benjamin S.",
                    "lastName": "Halpern"
                },
                {
                    "creatorType": "author",
                    "firstName": "Kimberly A.",
