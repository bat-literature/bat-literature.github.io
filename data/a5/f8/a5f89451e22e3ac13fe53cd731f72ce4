            "itemType": "journalArticle",
            "title": "iNaturalist Users Exhibit Distinct Spatiotemporal Sampling Preferences, with Implications for Biodiversity Science and Project Planning",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Erin L.",
                    "lastName": "Grady"
                },
                {
                    "creatorType": "author",
