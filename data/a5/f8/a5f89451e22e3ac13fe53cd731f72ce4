            "itemType": "journalArticle",
            "title": "Post-White-nose syndrome trends in Virginias cave bats, 2008-2013",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "E Powers",
                    "lastName": "Karen"
                },
                {
