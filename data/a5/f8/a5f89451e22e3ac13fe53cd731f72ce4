            "title": "Tracing the Origin of Dietary Protein in Tropical Dry Forest Birds",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "L. Gerardo",
                    "lastName": "Herrera M."
                },
                {
                    "creatorType": "author",
