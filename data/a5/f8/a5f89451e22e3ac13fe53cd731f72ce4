            "title": "Temporal and intrapopulation variation in prey choice of wintering geese determined by stable isotope analysis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Richard",
                    "lastName": "Inger"
                },
                {
                    "creatorType": "author",
                    "firstName": "Graeme D.",
                    "lastName": "Ruxton"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jason",
