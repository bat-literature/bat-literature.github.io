            "itemType": "journalArticle",
            "title": "A network of bat caves in Brazilian drylands support population connectivity in Pteronotus bats (Chiroptera: Mormoopidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Fernanda",
                    "lastName": "Ito"
                },
                {
                    "creatorType": "author",
                    "firstName": "Veronika N.",
