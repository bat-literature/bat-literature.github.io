            "title": "Molecular Survey of Protist Enteroparasites in Bats (Order Chiroptera) from Portugal",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pedro",
                    "lastName": "López-López"
                },
                {
                    "creatorType": "author",
                    "firstName": "Andreia V. S.",
                    "lastName": "Cruz"
                },
                {
                    "creatorType": "author",
                    "firstName": "Sérgio",
                    "lastName": "Santos-Silva"
                },
                {
                    "creatorType": "author",
