            "itemType": "journalArticle",
            "title": "‘No cost of echolocation for flying bats’ revisited",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christian C.",
                    "lastName": "Voigt"
                },
                {
                    "creatorType": "author",
                    "firstName": "Daniel",
                    "lastName": "Lewanzik"
