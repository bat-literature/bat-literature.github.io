        "data": {
            "key": "8R9L3WMQ",
            "version": 84561,
            "itemType": "journalArticle",
            "title": "Analysis of partial sequences of the RNA-dependent RNA polymerase gene as a tool for genus and subgenus classification of coronaviruses",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "David A.",
                    "lastName": "Wilkinson"
                },
                {
                    "creatorType": "author",
                    "firstName": "Léa",
