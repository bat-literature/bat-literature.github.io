            "itemType": "journalArticle",
            "title": "Tree-Based Methods as an Alternative to Logistic Regression in Revealing Risk Factors of Crib-Biting in Horses",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Krisztina",
                    "lastName": "Nagy"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jenő",
                    "lastName": "Reiczigel"
                },
