            "itemType": "journalArticle",
            "title": "Genetic Signature of Reproductive Manipulation in the Phylogeography of the Bat Fly, Trichobius major",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Justin B.",
                    "lastName": "Lack"
