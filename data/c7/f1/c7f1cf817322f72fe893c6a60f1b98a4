            "title": "Losing your edge: climate change and the conservation value of range‐edge populations",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Evan M.",
                    "lastName": "Rehm"
                },
                {
                    "creatorType": "author",
