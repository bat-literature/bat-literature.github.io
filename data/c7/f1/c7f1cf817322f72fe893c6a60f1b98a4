            "itemType": "journalArticle",
            "title": "Which uncertainty? Using expert elicitation and expected value of information to design an adaptive program",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Michael C.",
                    "lastName": "Runge"
                },
                {
                    "creatorType": "author",
