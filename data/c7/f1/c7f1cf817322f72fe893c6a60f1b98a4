            "title": "Italy as a major Ice Age refuge area for the bat Myotis myotis (Chiroptera: Vespertilionidae) in Europe",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Manuel",
                    "lastName": "Ruedi"
                },
                {
                    "creatorType": "author",
