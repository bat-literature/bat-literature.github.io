            "itemType": "journalArticle",
            "title": "Strong bat predation and weak environmental constraints predict longer moth tails",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Juliette J.",
                    "lastName": "Rubin"
                },
                {
                    "creatorType": "author",
