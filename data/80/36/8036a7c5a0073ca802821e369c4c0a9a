        "data": {
            "key": "8PHRBECC",
            "version": 13777,
            "itemType": "journalArticle",
            "title": "Conditional variable importance for random forests",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Carolin",
                    "lastName": "Strobl"
                },
                {
                    "creatorType": "author",
                    "firstName": "Anne-Laure",
                    "lastName": "Boulesteix"
                },
                {
                    "creatorType": "author",
                    "firstName": "Thomas",
