            "title": "Ecological and life-history traits predict bee species responses to environmental disturbances",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Neal M.",
                    "lastName": "Williams"
                },
                {
                    "creatorType": "author",
                    "firstName": "Elizabeth E.",
                    "lastName": "Crone"
                },
                {
                    "creatorType": "author",
