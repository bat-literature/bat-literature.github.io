            "title": "Environmental and anthropogenic factors structuring waterbird habitats of tropical coastal lagoons: Implications for management",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Davi Castro",
                    "lastName": "Tavares"
                },
                {
                    "creatorType": "author",
                    "firstName": "Demétrio Luis",
                    "lastName": "Guadagnin"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jailson Fulgencio",
                    "lastName": "De Moura"
