            "itemType": "journalArticle",
            "title": "Threshold Responses of Forest Birds to Landscape Changes around Exurban Development",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marcela",
                    "lastName": "Suarez-Rubio"
                },
                {
                    "creatorType": "author",
                    "firstName": "Scott",
                    "lastName": "Wilson"
                },
                {
                    "creatorType": "author",
                    "firstName": "Peter",
