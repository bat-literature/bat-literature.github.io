            "itemType": "journalArticle",
            "title": "Ventral wing hairs provide tactile feedback for aerial prey capture in the big brown bat, Eptesicus fuscus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Brittney L.",
                    "lastName": "Boublil"
                },
                {
