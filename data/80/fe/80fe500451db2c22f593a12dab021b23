            "title": "The global palm oil sector must change to save biodiversity and improve food security in the tropics",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Badrul",
                    "lastName": "Azhar"
                },
                {
                    "creatorType": "author",
                    "firstName": "Norzanalia",
