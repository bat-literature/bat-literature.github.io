            "itemType": "journalArticle",
            "title": "Seasonal intake responses in the nectar-feeding bat Glossophaga soricina",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jorge",
                    "lastName": "Ayala-Berdon"
                },
                {
                    "creatorType": "author",
