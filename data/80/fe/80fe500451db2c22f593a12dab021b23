            "title": "How do tiger moths jam bat sonar?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Aaron J.",
                    "lastName": "Corcoran"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jesse R.",
