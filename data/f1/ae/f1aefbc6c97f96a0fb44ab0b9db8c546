            "title": "Shared Ancestry between a Newfound Mole-Borne Hantavirus and Hantaviruses Harbored by Cricetid Rodents",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Hae Ji",
                    "lastName": "Kang"
                },
                {
                    "creatorType": "author",
                    "firstName": "Shannon N.",
                    "lastName": "Bennett"
                },
