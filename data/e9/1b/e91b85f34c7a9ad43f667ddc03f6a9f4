            "title": "EFFECT OF LAND DISTURBANCE AND STRESS ON SPECIES TRAITS OF GROUND BEETLE ASSEMBLAGES",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ignacio",
                    "lastName": "Ribera"
                },
                {
                    "creatorType": "author",
