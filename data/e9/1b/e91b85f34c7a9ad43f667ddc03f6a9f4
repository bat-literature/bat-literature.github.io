            "title": "Anuran abundance and persistence in agricultural landscapes during a climatic extreme",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Henna",
                    "lastName": "Piha"
                },
                {
                    "creatorType": "author",
                    "firstName": "Miska",
