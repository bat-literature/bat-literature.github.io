            "title": "Using Fecal Glucocorticoids to Assess Stress Levels in Captive River Otters",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Devon M.",
                    "lastName": "Rothschild"
                },
                {
                    "creatorType": "author",
