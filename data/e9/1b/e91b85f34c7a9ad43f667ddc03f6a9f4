            "title": "Conserving biodiversity in managed forest landscapes: The use of critical thresholds for habitat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ghislain",
                    "lastName": "Rompré"
                },
                {
                    "creatorType": "author",
                    "firstName": "Yan",
                    "lastName": "Boucher"
                },
                {
                    "creatorType": "author",
                    "firstName": "Louis",
