            "itemType": "journalArticle",
            "title": "Ecology, evolution and classification of bat coronaviruses in the aftermath of SARS",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jan Felix",
                    "lastName": "Drexler"
