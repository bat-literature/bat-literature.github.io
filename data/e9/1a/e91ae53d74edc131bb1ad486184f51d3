            "itemType": "journalArticle",
            "title": "Wing Ecomorphology and Flight Performance of Bats in Pisan Caves, Kabacan, North Cotabato, Philippines",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Krizler C",
                    "lastName": "Tanalgo"
                },
                {
                    "creatorType": "author",
