            "title": "Spatiotemporal patterns of riparian bat assemblages in a novel riparian ecosystem",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jessica",
                    "lastName": "Lin"
                },
                {
                    "creatorType": "author",
