            "title": "Bat Activity in the Boreal Forest: Importance of Stand Type and Vertical Strata",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "M. C.",
                    "lastName": "Kalcounis"
                },
                {
                    "creatorType": "author",
                    "firstName": "K. A.",
