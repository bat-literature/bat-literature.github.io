            "title": "Implications of forest management practices for sex-specific habitat use by Nycticeius humeralis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Youngsang",
                    "lastName": "Kwon"
                },
                {
                    "creatorType": "author",
                    "firstName": "Anna C",
                    "lastName": "Doty"
                },
                {
                    "creatorType": "author",
                    "firstName": "Megan L",
                    "lastName": "Huffman"
                },
                {
                    "creatorType": "author",
