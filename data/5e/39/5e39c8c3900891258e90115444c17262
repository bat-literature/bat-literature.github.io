            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "J. B.",
                    "lastName": "Nizeyi"
                },
                {
                    "creatorType": "author",
                    "firstName": "R.",
                    "lastName": "Mwebe"
                },
                {
                    "creatorType": "author",
