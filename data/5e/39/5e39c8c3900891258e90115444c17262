            "title": "Early establishment of diverse T cell receptor profiles for influenza-specific CD8+CD62Lhi memory T cells",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "K.",
                    "lastName": "Kedzierska"
                },
                {
