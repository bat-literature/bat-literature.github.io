        "data": {
            "key": "DJ4KPFZU",
            "version": 81457,
            "itemType": "journalArticle",
            "title": "Biodiversity Conservation in Tropical Agroecosystems: A New Conservation Paradigm",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ivette",
                    "lastName": "Perfecto"
