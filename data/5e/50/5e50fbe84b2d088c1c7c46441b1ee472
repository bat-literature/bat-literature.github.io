        "data": {
            "key": "PC63F46T",
            "version": 81469,
            "itemType": "journalArticle",
            "title": "Seasonal glucocorticoid responses to capture in wild free-living mammals",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "L. Michael",
                    "lastName": "Romero"
                },
                {
                    "creatorType": "author",
                    "firstName": "Cecile J.",
                    "lastName": "Meister"
                },
                {
                    "creatorType": "author",
                    "firstName": "Nicole E.",
