            "itemType": "journalArticle",
            "title": "Simple quantification of blood and plasma antimicrobial capacity using spectrophotometry",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Andrea L.",
                    "lastName": "Liebl"
                },
                {
                    "creatorType": "author",
                    "firstName": "Lynn B.",
                    "lastName": "Martin Ii"
