            "itemType": "journalArticle",
            "title": "Use of fecal glucocorticoid metabolite measures in conservation biology research: considerations for application and interpretation",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Joshua J.",
                    "lastName": "Millspaugh"
