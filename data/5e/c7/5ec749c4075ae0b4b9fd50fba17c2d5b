            "title": "Beyond size – morphological predictors of bite force in a diverse insectivorous bat assemblage from Malaysia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Juliana",
                    "lastName": "Senawi"
                },
                {
                    "creatorType": "author",
                    "firstName": "Daniela",
