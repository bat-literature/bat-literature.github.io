            "itemType": "journalArticle",
            "title": "Rethinking the conceptual foundations of habitat fragmentation research",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Raphael K.",
                    "lastName": "Didham"
                },
                {
                    "creatorType": "author",
