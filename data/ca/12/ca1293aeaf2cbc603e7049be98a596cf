            "itemType": "journalArticle",
            "title": "The bat fauna hibernating in the caves of the Polish Tatra Mountains, and its long-term changes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Krzysztof",
                    "lastName": "Piksa"
