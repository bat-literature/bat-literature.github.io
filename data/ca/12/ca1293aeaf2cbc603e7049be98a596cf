            "itemType": "journalArticle",
            "title": "Habitat fragmentation and haemoparasites in the common fruit bat, Artibeus jamaicensis (Phyllostomidae) in a tropical lowland forest in Panam",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "V. M.",
                    "lastName": "Cottontail"
                },
                {
                    "creatorType": "author",
                    "firstName": "N.",
