            "itemType": "journalArticle",
            "title": "MEASURING INDIVIDUAL-LEVEL RESOURCE SPECIALIZATION",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel I",
                    "lastName": "Bolnick"
                },
                {
                    "creatorType": "author",
