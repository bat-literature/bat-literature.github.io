            "title": "Rapid evolution of disease resistance is accompanied by functional changes in gene expression in a wild bird",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Camille",
                    "lastName": "Bonneaud"
                },
                {
                    "creatorType": "author",
                    "firstName": "Susan L.",
