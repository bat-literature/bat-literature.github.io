            "title": "Huddling reduces evaporative water loss in torpid Natterer's bats, Myotis nattereri",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jan S.",
                    "lastName": "Boratyński"
                },
                {
                    "creatorType": "author",
