            "title": "Ocorrência de Giardia, Cryptosporidium e microsporídios em animais silvestres em área de desmatamento no Estado de São Paulo, Brasil",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maria Anete",
