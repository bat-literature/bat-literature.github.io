            "itemType": "journalArticle",
            "title": "Estimation of demographic fluctuations within a reproductive roost of Pipistrellus kuhlii inferred from capture-mark-recapture data",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alessandro",
