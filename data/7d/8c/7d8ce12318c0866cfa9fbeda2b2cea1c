            "itemType": "bookSection",
            "title": "Variable Energetic Strategies in Disturbed and Undisturbed Rain Forests: Eulemur rubriventer Fecal Cortisol Levels in South-Eastern Madagascar",
            "creators": [
                {
                    "creatorType": "editor",
