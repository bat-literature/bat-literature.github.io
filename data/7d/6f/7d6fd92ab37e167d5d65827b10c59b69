            "title": "The buffy coat method: a tool for detection of blood parasites without staining procedures",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Carolina R. F.",
                    "lastName": "Chagas"
                },
                {
                    "creatorType": "author",
