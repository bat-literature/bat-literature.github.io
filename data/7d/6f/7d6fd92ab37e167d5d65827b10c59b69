            "itemType": "journalArticle",
            "title": "The relative contribution of diurnal and nocturnal pollinators to plant female fitness in a specialized nursery pollination system",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Giovanni",
                    "lastName": "Scopece"
                },
                {
                    "creatorType": "author",
                    "firstName": "Lucia",
