            "title": "Molecular Differentiation of Large Species of Fruit-Eating Bats (Artibeus) and Phylogenetic Relationships Based on the Cytochrome Gene",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Burton K.",
                    "lastName": "Lim"
                },
                {
                    "creatorType": "author",
