            "itemType": "journalArticle",
            "title": "Winter and Summer Torpor in a Free-Ranging Subtropical Desert Bat: The Fishing Myotis (Myotis vivesi)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Valeria B.",
                    "lastName": "Salinas R."
                },
                {
                    "creatorType": "author",
