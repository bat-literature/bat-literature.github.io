            "itemType": "journalArticle",
            "title": "Review: Fifty years of research on rumen methanogenesis: lessons learned and future challenges for mitigation",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "K.A.",
                    "lastName": "Beauchemin"
                },
                {
                    "creatorType": "author",
                    "firstName": "E.M.",
