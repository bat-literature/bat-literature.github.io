            "title": "Does pollination syndrome reflect pollinator efficiency in Silene nutans?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maryse",
                    "lastName": "Vanderplanck"
                },
                {
                    "creatorType": "author",
