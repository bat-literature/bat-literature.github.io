            "itemType": "journalArticle",
            "title": "Horseshoe Bats Recognise the Sex of Conspecifics from Their Echolocation Calls",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maike",
                    "lastName": "Schuchmann"
                },
                {
                    "creatorType": "author",
