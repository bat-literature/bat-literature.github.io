            "itemType": "journalArticle",
            "title": "Critical times of the year for Myotis myotis, a temperate zone bat: roles of climate and food resources",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Andreas",
                    "lastName": "Zahn"
                },
                {
                    "creatorType": "author",
                    "firstName": "Luísa",
