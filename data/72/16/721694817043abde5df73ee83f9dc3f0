            "itemType": "journalArticle",
            "title": "Maternal feeding of offspring with vertebrate prey in captive Indian false vampire bat, Megaderma lyra",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Hanumanthan",
                    "lastName": "Raghuram"
                },
                {
