            "itemType": "journalArticle",
            "title": "Taxonomy of little bent-winged bats (Miniopterus, Miniopteridae) from the African islands of São Tomé, Grand Comoro and Madagascar, based on mtDNA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Javier",
                    "lastName": "Juste"
                },
                {
