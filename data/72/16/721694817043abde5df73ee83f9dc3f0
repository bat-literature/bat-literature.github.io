            "title": "Bats of Saba, Netherlands Antilles: a zoogeographic perspective",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Hugh H.",
                    "lastName": "Genoways"
                },
                {
                    "creatorType": "author",
