            "itemType": "journalArticle",
            "title": "Assemblage and Species Threshold Responses to Environmental and Disturbance Gradients Shape Bat Diversity in Disturbed Cave Landscapes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Kendra",
                    "lastName": "Phelps"
                },
