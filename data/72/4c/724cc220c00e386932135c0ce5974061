            "itemType": "journalArticle",
            "title": "A meta‐analysis exploring associations between habitat degradation and Neotropical bat virus prevalence and seroprevalence",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alexis M.",
                    "lastName": "Heckley"
                },
                {
                    "creatorType": "author",
