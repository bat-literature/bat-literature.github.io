            "itemType": "journalArticle",
            "title": "Disease associated with integumentary and cloacal parasites in tadpoles of northern red-legged frog Rana aurora aurora",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nc",
                    "lastName": "Nieto"
                },
                {
                    "creatorType": "author",
