            "itemType": "journalArticle",
            "title": "A Comparative Analysis of Viral Richness and Viral Sharing in Cave-Roosting Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Anna R.",
                    "lastName": "Willoughby"
