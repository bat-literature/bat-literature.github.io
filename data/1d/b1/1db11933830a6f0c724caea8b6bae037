            "title": "Bat responses to silviculture treatments: Activity over 13 years of regeneration",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel W.",
                    "lastName": "Wright"
                },
                {
                    "creatorType": "author",
                    "firstName": "Chadwick D.",
