            "itemType": "journalArticle",
            "title": "Animal sales from Wuhan wet markets immediately prior to the COVID-19 pandemic",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Xiao",
                    "lastName": "Xiao"
                },
                {
                    "creatorType": "author",
