            "title": "Echolocation calls produced by Kuhl's pipistrelles in different flight situations",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "O.",
                    "lastName": "Berger‐Tal"
                },
                {
                    "creatorType": "author",
