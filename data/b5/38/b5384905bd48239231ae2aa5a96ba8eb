            "title": "Variations in the echolocation calls of the European free‐tailed bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "S.",
                    "lastName": "Bayefsky‐Anand"
                },
                {
                    "creatorType": "author",
                    "firstName": "M. D.",
                    "lastName": "Skowronski"
                },
                {
                    "creatorType": "author",
                    "firstName": "M. B.",
