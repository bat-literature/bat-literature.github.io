            "title": "The presence of wind turbines repels bats in boreal forests",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Simon P.",
                    "lastName": "Gaultier"
                },
                {
                    "creatorType": "author",
                    "firstName": "Thomas M.",
