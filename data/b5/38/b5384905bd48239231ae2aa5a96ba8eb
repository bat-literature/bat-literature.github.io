            "title": "Diet and prey selection in the trawling long‐fingered bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D.",
                    "lastName": "Almenar"
                },
                {
                    "creatorType": "author",
                    "firstName": "J.",
                    "lastName": "Aihartza"
                },
                {
                    "creatorType": "author",
                    "firstName": "U.",
                    "lastName": "Goiti"
                },
                {
                    "creatorType": "author",
