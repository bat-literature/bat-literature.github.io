            "itemType": "journalArticle",
            "title": "First Records of Butterfly Diversity on Two Remote Islands on the Volta Lake of Ghana, the Largest Reservoir by Total Surface Area in the World",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel Opoku",
                    "lastName": "Agyemang"
                },
                {
                    "creatorType": "author",
