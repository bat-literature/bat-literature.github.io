            "itemType": "journalArticle",
            "title": "Balancing the benefits of ecotourism and development: The effects of visitor trail-use on mammals in a Protected Area in rapidly developing China",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Youbing",
                    "lastName": "Zhou"
                },
                {
                    "creatorType": "author",
                    "firstName": "Christina D.",
                    "lastName": "Buesching"
                },
                {
                    "creatorType": "author",
                    "firstName": "Chris",
                    "lastName": "Newman"
                },
