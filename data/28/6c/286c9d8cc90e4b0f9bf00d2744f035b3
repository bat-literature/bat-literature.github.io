            "itemType": "journalArticle",
            "title": "MORPHOLOGICAL ANALYSIS AND DESCRIPTION OF TWO NEW SPECIES OF RHOGEESSA  (CHIROPTERA: VESPERTILIONIDAE) FROM THE NEOTROPICS",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Amy B.",
                    "lastName": "Baird"
                },
                {
                    "creatorType": "author",
                    "firstName": "MARÍA R.",
                    "lastName": "MARCHÁN-RIVADENEIRA"
                },
                {
