            "itemType": "journalArticle",
            "title": "The roles of energetics, water economy, foraging behavior, and geothermal refugia in the distribution of the bat, Macrotus cMifornicus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Gary P",
                    "lastName": "Bell"
                },
                {
                    "creatorType": "author",
                    "firstName": "George A",
