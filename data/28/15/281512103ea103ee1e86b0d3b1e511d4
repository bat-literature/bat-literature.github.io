        "data": {
            "key": "XADLA7DA",
            "version": 74733,
            "itemType": "journalArticle",
            "title": "Tetrastylis ovMis: a second case of bat-pollinated passionflower (Passitloraceae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Silvana",
                    "lastName": "Buzato"
                },
