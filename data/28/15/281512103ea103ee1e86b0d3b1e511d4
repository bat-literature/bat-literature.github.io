            "title": "Seasonality and the dynamics of infectious diseases",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sonia",
                    "lastName": "Altizer"
                },
                {
                    "creatorType": "author",
                    "firstName": "Andrew",
                    "lastName": "Dobson"
                },
                {
                    "creatorType": "author",
