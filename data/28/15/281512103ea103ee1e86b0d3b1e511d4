        "data": {
            "key": "BHBX4MPF",
            "version": 74722,
            "itemType": "journalArticle",
            "title": "Interspecific competition and niche partitioning: example of a neotropical rainforest bat community",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marguerite",
