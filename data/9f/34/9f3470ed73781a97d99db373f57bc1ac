            "itemType": "journalArticle",
            "title": "Testing for Homogeneity of Multivariate Dispersions Using Dissimilarity Measures",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Irène",
                    "lastName": "Gijbels"
                },
                {
                    "creatorType": "author",
                    "firstName": "Marek",
                    "lastName": "Omelka"
