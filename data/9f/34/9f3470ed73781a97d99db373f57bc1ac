            "itemType": "journalArticle",
            "title": "Collection of Scientific Specimens: Benefits for Biodiversity Sciences and Limited Impacts on Communities of Small Mammals",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Andrew G",
                    "lastName": "Hope"
                },
                {
                    "creatorType": "author",
                    "firstName": "Brett K",
