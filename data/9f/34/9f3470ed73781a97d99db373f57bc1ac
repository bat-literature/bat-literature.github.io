            "title": "Habitat loss, fragmentation and degradation effects on small mammals: Analysis with conditional inference tree statistical modelling",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christopher P.",
                    "lastName": "Johnstone"
                },
                {
                    "creatorType": "author",
