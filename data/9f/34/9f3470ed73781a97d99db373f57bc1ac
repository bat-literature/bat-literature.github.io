            "title": "Assessing the performance of nonparametric estimators of species richness in meadows",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "José Antonio",
                    "lastName": "González-Oreja"
                },
                {
                    "creatorType": "author",
                    "firstName": "Carlos",
                    "lastName": "Garbisu"
                },
                {
                    "creatorType": "author",
                    "firstName": "Sorkunde",
