            "itemType": "journalArticle",
            "title": "Effects of Omnidirectional Microphone Placement and Survey Period on Bat Echolocation Call Quality and Detection Probabilities",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Susan C.",
                    "lastName": "Loeb"
                },
                {
                    "creatorType": "author",
