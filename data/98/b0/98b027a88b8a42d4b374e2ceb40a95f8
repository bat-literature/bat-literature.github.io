        "data": {
            "key": "YXNSLEWX",
            "version": 28895,
            "itemType": "journalArticle",
            "title": "Using Echolocation Calls to Identify Thai Bat Species: Vespertilionidae, Emballonuridae, Nycteridae and Megadermatidae",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alice C.",
                    "lastName": "Hughes"
                },
                {
