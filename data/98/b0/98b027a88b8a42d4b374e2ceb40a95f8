            "itemType": "journalArticle",
            "title": "A survey of hard ticks associated with cave dwelling mammals in Turkey",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Olcay",
                    "lastName": "Hekimoglu"
                },
                {
                    "creatorType": "author",
