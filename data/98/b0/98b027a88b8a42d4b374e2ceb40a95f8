            "itemType": "journalArticle",
            "title": "Relationship between Spatial Working Memory Performance and Diet Specialization in Two Sympatric Nectar Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mickaël",
                    "lastName": "Henry"
                },
                {
                    "creatorType": "author",
