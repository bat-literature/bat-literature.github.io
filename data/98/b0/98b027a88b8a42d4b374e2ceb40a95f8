            "itemType": "journalArticle",
            "title": "First Report of Alphacoronavirus Circulating in Cavernicolous Bats from Portugal",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mahima",
                    "lastName": "Hemnani"
                },
                {
                    "creatorType": "author",
