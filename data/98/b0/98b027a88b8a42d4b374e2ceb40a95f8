        "data": {
            "key": "FXP2TUNM",
            "version": 73251,
            "itemType": "bookSection",
            "title": "Rapid Assessment Program (RAP) Survey of Small Mammals in the Grensgebergte and Kasikasima Region of Southeastern Suriname",
            "creators": [
                {
                    "creatorType": "editor",
                    "firstName": "Leeanne E.",
                    "lastName": "Alonso"
                },
                {
                    "creatorType": "bookAuthor",
                    "firstName": "Trond H.",
                    "lastName": "Larsen"
                },
                {
                    "creatorType": "author",
