            "title": "Influence of Reservoirs Created by Small Dams on the Activity of Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Frederico",
                    "lastName": "Hintze"
                },
                {
                    "creatorType": "author",
                    "firstName": "Virgínia",
