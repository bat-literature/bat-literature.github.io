            "itemType": "journalArticle",
            "title": "Evening Bat Summer Roost‐Site Selection on a Managed Pine Landscape",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Cris D.",
                    "lastName": "Hein"
                },
                {
                    "creatorType": "author",
