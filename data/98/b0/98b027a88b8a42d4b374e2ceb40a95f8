            "itemType": "journalArticle",
            "title": "Male Seminole Bat Winter Roost‐Site Selection in a Managed Forest",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Cris D.",
                    "lastName": "Hein"
