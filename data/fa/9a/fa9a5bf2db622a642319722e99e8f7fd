            "itemType": "journalArticle",
            "title": "Production and partial purification of extracellular xylanase from Pseudomonas nitroreducens using frugivorous bat (Pteropus giganteus) faeces as ideal substrate and its role in poultry feed digestion",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "J",
                    "lastName": "Dhivahar"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ameer",
                    "lastName": "Khusro"
                },
                {
                    "creatorType": "author",
