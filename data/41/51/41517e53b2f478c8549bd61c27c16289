            "itemType": "journalArticle",
            "title": "A tale of two genomes: contrasting patterns of phylogeographic structure in a widely distributed bat: PHYLOGEOGRAPHY OF BIG BROWN BATS",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Amy S.",
