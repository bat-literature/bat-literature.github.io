            "itemType": "journalArticle",
            "title": "Oxidation of dietary sugar during hovering flight in small vertebrate nectarivores",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "K. C.",
                    "lastName": "Welch"
                },
