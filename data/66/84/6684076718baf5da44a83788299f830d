            "itemType": "journalArticle",
            "title": "Universality of Torpor Expression in Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mari Aas",
                    "lastName": "Fjelldal"
                },
                {
                    "creatorType": "author",
