            "version": 56475,
            "itemType": "journalArticle",
            "title": "Protecting bias: Across time and ecology, open-source bat locality data are heavily biased by distance to protected area",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marina",
                    "lastName": "Fisher-Phelps"
                },
                {
                    "creatorType": "author",
                    "firstName": "Guofeng",
