            "itemType": "journalArticle",
            "title": "FRUIT CHOICE AND CALCIUM BLOCK USE BY TONGAN FRUIT BATS IN AMERICAN SAMOA",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Suzanne L.",
                    "lastName": "Nelson"
                },
                {
