        "data": {
            "key": "N82CJZFM",
            "version": 56174,
            "itemType": "journalArticle",
            "title": "Inflammasome regulation in driving COVID-19 severity in humans and immune tolerance in bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sahana",
                    "lastName": "Nagaraja"
