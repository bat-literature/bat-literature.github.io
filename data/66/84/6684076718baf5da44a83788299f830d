            "title": "A NEW SPECIES OF ANOURA (CHIROPTERA: PHYLLOSTOMIDAE) FROM THE ECUADORIAN ANDES",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nathan",
