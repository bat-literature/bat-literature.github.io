            "title": "Pharmaceutical Screening of Bat Feces and Their Applications and Risks in Traditional Chinese Medicine",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Kou-Toung",
                    "lastName": "Chung"
                },
                {
                    "creatorType": "author",
