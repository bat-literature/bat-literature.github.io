            "itemType": "journalArticle",
            "title": "Testing Predictions of Optimal Migration Theory in Migratory Bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jeff",
                    "lastName": "Clerc"
                },
                {
                    "creatorType": "author",
