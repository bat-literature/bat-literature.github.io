            "title": "Coronavirus sampling and surveillance in bats from 1996-2019: a systematic review and meta-analysis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lily E.",
                    "lastName": "Cohen"
                },
                {
