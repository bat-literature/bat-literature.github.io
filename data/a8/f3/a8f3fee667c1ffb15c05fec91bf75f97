            "itemType": "journalArticle",
            "title": "Borrelia in neotropical bats: Detection of two new phylogenetic lineages",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pablo",
                    "lastName": "Colunga-Salas"
                },
                {
                    "creatorType": "author",
