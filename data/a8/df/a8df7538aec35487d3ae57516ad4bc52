            "itemType": "journalArticle",
            "title": "Gene flow and population structure of the endemic Azorean bat (Nyctalus azoreum) based on microsatellites: implications for conservation",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Patrícia",
