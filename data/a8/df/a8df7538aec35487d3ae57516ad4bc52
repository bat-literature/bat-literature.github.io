            "itemType": "journalArticle",
            "title": "Ecology of small mammals in a gallery forest of Central Brazil.",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Leslie Zuhn",
                    "lastName": "Nitikman"
                },
                {
                    "creatorType": "author",
                    "firstName": "Michael A.",
                    "lastName": "Mares"
