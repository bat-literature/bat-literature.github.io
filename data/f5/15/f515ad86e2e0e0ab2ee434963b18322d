            "title": "Are Burrow Nesting Seabird Chicks Affected by Human Disturbance?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Yuri V.",
                    "lastName": "Albores-Barajas"
                },
                {
                    "creatorType": "author",
