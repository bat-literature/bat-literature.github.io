            "title": "Umbrellas and flagships: Efficient conservation surrogates or expensive mistakes?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sandy J.",
                    "lastName": "Andelman"
                },
                {
                    "creatorType": "author",
                    "firstName": "William F.",
                    "lastName": "Fagan"
