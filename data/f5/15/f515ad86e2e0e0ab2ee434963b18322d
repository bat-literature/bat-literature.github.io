            "title": "Evaluation of Local Ecological Knowledge as a Method for Collecting Extensive Data on Animal Abundance",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "José Daniel",
                    "lastName": "Anadón"
                },
                {
                    "creatorType": "author",
                    "firstName": "Andrés",
