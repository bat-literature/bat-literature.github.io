            "title": "Behavioral consequences of innate preferences and olfactory learning in hawkmoth–flower interactions",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jeffrey A.",
                    "lastName": "Riffell"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ruben",
