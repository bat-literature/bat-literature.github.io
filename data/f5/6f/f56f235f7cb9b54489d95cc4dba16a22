        "data": {
            "key": "EBQ8CUMY",
            "version": 44006,
            "itemType": "journalArticle",
            "title": "Nectar Robbing Positively Influences the Reproductive Success of Tecomella undulata (Bignoniaceae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Vineet Kumar",
                    "lastName": "Singh"
                },
                {
                    "creatorType": "author",
