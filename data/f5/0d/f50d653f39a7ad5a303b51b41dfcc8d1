            "title": "Effect of environmental gradients on community structuring of aerial insectivorous bats in a continuous forest in Central Amazon",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ricardo Cesar C.",
                    "lastName": "Cabral"
                },
                {
                    "creatorType": "author",
                    "firstName": "Giulliana",
                    "lastName": "Appel"
                },
                {
                    "creatorType": "author",
                    "firstName": "Leonardo Queiroz",
                    "lastName": "De Oliveira"
                },
                {
                    "creatorType": "author",
                    "firstName": "Adrià",
