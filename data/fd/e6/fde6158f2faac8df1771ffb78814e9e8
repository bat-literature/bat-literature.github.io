            "title": "Controlling the taxonomic variable: Taxonomic concept resolution for a southeastern United States herbarium portal",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nico",
                    "lastName": "Franz"
                },
                {
                    "creatorType": "author",
