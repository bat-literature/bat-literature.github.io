            "itemType": "journalArticle",
            "title": "A new type of tandem repeats in Myotis petax (Chiroptera, Vespertilionidae) mitochondrial control region",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Uliana Vasilievna",
                    "lastName": "Gorobeyko"
                },
                {
                    "creatorType": "author",
