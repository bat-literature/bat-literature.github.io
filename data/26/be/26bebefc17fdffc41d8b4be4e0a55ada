            "itemType": "journalArticle",
            "title": "What Do Nectarivorous Bats Like? Nectar Composition in Bromeliaceae With Special Emphasis on Bat-Pollinated Species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Thomas",
                    "lastName": "Göttlinger"
                },
