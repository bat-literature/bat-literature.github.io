            "itemType": "journalArticle",
            "title": "A new genus of vespertilionid bat: the end of a long journey for Joffre’s Pipistrelle (Chiroptera: Vespertilionidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Tamás",
