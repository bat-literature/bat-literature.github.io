        "data": {
            "key": "HD5M5D2S",
            "version": 85787,
            "itemType": "journalArticle",
            "title": "The phylogeography of Myotis bat-associated rabies viruses across Canada",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Susan",
                    "lastName": "Nadin-Davis"
                },
                {
                    "creatorType": "author",
                    "firstName": "Noor",
