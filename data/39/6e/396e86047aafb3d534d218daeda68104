            "itemType": "journalArticle",
            "title": "Determining Feeding State and Rate of Mass Change in Insectivorous Bats Using Plasma Metabolite Analysis",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Liam P.",
                    "lastName": "McGuire"
                },
                {
                    "creatorType": "author",
