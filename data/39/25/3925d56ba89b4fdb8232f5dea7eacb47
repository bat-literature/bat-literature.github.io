            "itemType": "journalArticle",
            "title": "Acoustic divergence in two cryptic Hipposideros species: a role for social selection?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Tigga",
                    "lastName": "Kingston"
                },
                {
                    "creatorType": "author",
