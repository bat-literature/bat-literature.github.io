            "itemType": "journalArticle",
            "title": "Ghosts of infections past: using archival samples to understand a century of monkeypox virus prevalence among host communities across space and time",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Madeline S.",
                    "lastName": "Tiee"
                },
                {
                    "creatorType": "author",
