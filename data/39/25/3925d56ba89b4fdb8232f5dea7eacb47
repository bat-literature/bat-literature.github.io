        "data": {
            "key": "ZCUK7HBV",
            "version": 86239,
            "itemType": "journalArticle",
            "title": "Why infectious disease research needs community ecology",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pieter T. J.",
                    "lastName": "Johnson"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jacobus C.",
