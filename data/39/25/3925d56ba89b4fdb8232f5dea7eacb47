            "itemType": "journalArticle",
            "title": "Single-locus species delimitation: a test of the mixed Yule–coalescent model, with an empirical application to Philippine round-leaf bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jacob A.",
                    "lastName": "Esselstyn"
                },
                {
                    "creatorType": "author",
                    "firstName": "Ben J.",
                    "lastName": "Evans"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jodi L.",
