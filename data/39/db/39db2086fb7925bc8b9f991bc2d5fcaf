            "itemType": "journalArticle",
            "title": "Conservation implications of ameliorating survival of little brown bats with white‐nose syndrome",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Brooke",
                    "lastName": "Maslo"
                },
                {
                    "creatorType": "author",
