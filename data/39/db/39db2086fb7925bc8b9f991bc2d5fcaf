            "itemType": "journalArticle",
            "title": "Bat Diversity and Abundance as Indicators of Disturbance in Neotropical Rainforests",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Rodrigo A",
                    "lastName": "Medellín"
                },
                {
                    "creatorType": "author",
