            "title": "Variation of adult survival drives population dynamics in a migrating forest bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Wigbert",
                    "lastName": "Schorcht"
                },
                {
                    "creatorType": "author",
