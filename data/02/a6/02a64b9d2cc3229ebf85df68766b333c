            "title": "Pollen presentation and pollination syndromes, with special reference to Penstemon",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "James D.",
                    "lastName": "Thomson"
                },
                {
                    "creatorType": "author",
