            "itemType": "journalArticle",
            "title": "Rates of Viral Evolution Are Linked to Host Geography in Bat Rabies",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel G.",
                    "lastName": "Streicker"
                },
                {
                    "creatorType": "author",
                    "firstName": "Philippe",
                    "lastName": "Lemey"
                },
                {
                    "creatorType": "author",
                    "firstName": "Andres",
