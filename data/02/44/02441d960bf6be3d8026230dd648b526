        "data": {
            "key": "95EAUC5J",
            "version": 73124,
            "itemType": "journalArticle",
            "title": "Geographic translocation of bats: known and potential problems",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Denny G.",
                    "lastName": "Constantine"
                }
            ],
            "abstractNote": "Natural, accidental, and intentional translocation of bats, both intra- and intercontinentally, has been documented. Some bats have been translocated while incubating infectious diseases, including rabies or related lyssavirus infections; others have escaped confinement en route to or at their destinations, while others have been released deliberately. Known events and potential consequences of bat translocation are reviewed, including a proposed solution to the attendant problems.",
            "publicationTitle": "Emerging Infectious Diseases",
            "publisher": "",
