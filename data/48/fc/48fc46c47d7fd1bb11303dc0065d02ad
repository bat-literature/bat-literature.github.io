                    "lastName": "Sotero"
                },
                {
                    "creatorType": "author",
                    "firstName": "Cirley Gomes Araújo",
                    "lastName": "Dos Santos"
                },
                {
                    "creatorType": "author",
                    "firstName": "Rhayane Alves",
                    "lastName": "De Assis"
                },
                {
                    "creatorType": "author",
