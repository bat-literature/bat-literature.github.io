            "itemType": "journalArticle",
            "title": "Population Size Does Not Influence Mitochondrial Genetic Diversity in Animals",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Eric",
                    "lastName": "Bazin"
                },
                {
                    "creatorType": "author",
