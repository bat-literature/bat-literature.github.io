            "itemType": "journalArticle",
            "title": "Genotoxic, mutagenic, and cytotoxic analysis in bats in mining area",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Marcelino",
                    "lastName": "Benvindo-Souza"
                },
                {
                    "creatorType": "author",
