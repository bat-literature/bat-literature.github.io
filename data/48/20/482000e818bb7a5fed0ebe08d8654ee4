            "itemType": "journalArticle",
            "title": "The Evolutionary History of the African Fruit Bats (Chiroptera: Pteropodidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Francisca",
                    "lastName": "Cunhaalmeida"
                },
                {
                    "creatorType": "author",
