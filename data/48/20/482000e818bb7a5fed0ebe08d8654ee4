            "itemType": "journalArticle",
            "title": "The relationship between male sucker-footed bats Myzopoda aurita and the traveller’s tree Ravenala madagascariensis in south-eastern Madagascar",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Mahefatiana",
