        "data": {
            "key": "SHSA7ZG6",
            "version": 54317,
            "itemType": "journalArticle",
            "title": "Insight into the Identity and Origin of Scotophilus borbonicus (E. Geoffroy, 1803)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Steven M.",
                    "lastName": "Goodman"
                },
                {
                    "creatorType": "author",
                    "firstName": "Stephen",
