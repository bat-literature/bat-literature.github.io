            "key": "IFUVAK9I",
            "version": 54251,
            "itemType": "journalArticle",
            "title": "Quantification of Morphological Variation within Species of Anoura from Ecuador, with an Emphasis on A. fistulata (Chiroptera: Phyllostomidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pablo",
                    "lastName": "Jarrín-V"
                },
                {
                    "creatorType": "author",
