            "title": "A new species in the Hipposideros bicolor group (Chiroptera: Hipposideridae) from Peninsular Malaysia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Susan W.",
                    "lastName": "Murray"
                },
                {
                    "creatorType": "author",
