            "itemType": "journalArticle",
            "title": "Foraging behavior of a desert dwelling arthropod-gleaning bat (Otonycteris hemprichii) during pregnancy and nursing",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Shai",
