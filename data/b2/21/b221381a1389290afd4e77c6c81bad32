            "itemType": "journalArticle",
            "title": "Specific Status of Populations on Madagascar Referred to Miniopterus fraterculus (Chiroptera: Vespertilionidae), with Description of a New Species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "S. M.",
                    "lastName": "Goodman"
                },
                {
                    "creatorType": "author",
                    "firstName": "K. E.",
                    "lastName": "Ryan"
                },
                {
                    "creatorType": "author",
