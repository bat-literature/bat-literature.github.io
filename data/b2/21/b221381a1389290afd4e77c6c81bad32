        "data": {
            "key": "XNRUK32X",
            "version": 56322,
            "itemType": "journalArticle",
            "title": "The genus Neoromicia (Family Vespertilionidae) in Madagascar, with the description of a new species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Steven M.",
                    "lastName": "Goodman"
                },
                {
                    "creatorType": "author",
                    "firstName": "Peter J.",
