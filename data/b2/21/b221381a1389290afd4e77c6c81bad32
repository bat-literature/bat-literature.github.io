            "itemType": "journalArticle",
            "title": "Metagenomic analysis of viruses from bat fecal samples reveals many novel viruses in insectivorous bats in China",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Xingyi",
                    "lastName": "Ge"
                },
                {
                    "creatorType": "author",
