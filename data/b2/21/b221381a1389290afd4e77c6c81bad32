            "title": "Male Carollia perspicillata bats call more than females in a distressful context",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Eugenia",
                    "lastName": "González-Palomares"
                },
                {
                    "creatorType": "author",
