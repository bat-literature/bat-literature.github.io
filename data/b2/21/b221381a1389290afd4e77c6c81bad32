            "itemType": "journalArticle",
            "title": "Specific status of populations in the Mascarene Islands referred to Mormopterus acetabulosus (Chiroptera: Molossidae), with description of a new species",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "S. M.",
                    "lastName": "Goodman"
                },
                {
                    "creatorType": "author",
                    "firstName": "B. Jansen",
                    "lastName": "Van Vuuren"
                },
                {
                    "creatorType": "author",
                    "firstName": "F.",
