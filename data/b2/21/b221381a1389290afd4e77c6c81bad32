        "data": {
            "key": "NBR8Q8LX",
            "version": 56472,
            "itemType": "journalArticle",
            "title": "Behavioral patterns of bats at a wind turbine confirm seasonality of fatality risk",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Shifra Z.",
                    "lastName": "Goldenberg"
                },
                {
                    "creatorType": "author",
                    "firstName": "Paul M.",
