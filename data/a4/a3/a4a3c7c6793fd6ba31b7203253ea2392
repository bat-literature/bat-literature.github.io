            "title": "Using sutures to attach miniature tracking tags to small bats for multimonth movement and behavioral studies",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Kevin T.",
                    "lastName": "Castle"
                },
                {
                    "creatorType": "author",
