            "itemType": "journalArticle",
            "title": "Dynamic feeding habits: efficiency of frugivory in a nectarivorous bat",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nina I.",
                    "lastName": "Becker"
