        "data": {
            "key": "SN6SR3MK",
            "version": 77957,
            "itemType": "journalArticle",
            "title": "Behavioural Response of Bats to Perceived Predation Risk While Foraging",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel J. M.",
                    "lastName": "Baxter"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jennifer M.",
                    "lastName": "Psyllakis"
                },
