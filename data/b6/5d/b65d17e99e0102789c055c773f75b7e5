            "title": "Morphological Adaptations for Digging and Climate-Impacted Soil Properties Define Pocket Gopher (Thomomys spp.) Distributions",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Ariel E.",
                    "lastName": "Marcy"
                },
                {
                    "creatorType": "author",
