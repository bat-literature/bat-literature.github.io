            "title": "Functional responses of insectivorous bats to increasing housing density support ‘land‐sparing’ rather than ‘land‐sharing’ urban growth strategies",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Fiona M.",
                    "lastName": "Caryl"
                },
                {
                    "creatorType": "author",
                    "firstName": "Linda F.",
                    "lastName": "Lumsden"
                },
                {
                    "creatorType": "author",
                    "firstName": "Rodney",
                    "lastName": "Van Der Ree"
                },
                {
                    "creatorType": "author",
                    "firstName": "Brendan A.",
                    "lastName": "Wintle"
                },
                {
                    "creatorType": "editor",
                    "firstName": "Jeroen",
                    "lastName": "Minderman"
                }
