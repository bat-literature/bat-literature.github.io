            "title": "Crowding after sudden habitat loss affects demography and social structure in a bat population",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Francisco",
                    "lastName": "Amorim"
                },
                {
                    "creatorType": "author",
