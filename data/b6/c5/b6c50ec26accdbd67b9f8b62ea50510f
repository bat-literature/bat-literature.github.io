            "itemType": "journalArticle",
            "title": "The first record of European free-tailed bat, Tadarida teniotis Rafinesque, 1814, and note on probable elevational movement from Nepal",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Basant",
                    "lastName": "Sharma"
                },
                {
                    "creatorType": "author",
