            "title": "Bat phylogenetic responses to regenerating Amazonian forests",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Fábio Z.",
                    "lastName": "Farneda"
                },
                {
                    "creatorType": "author",
