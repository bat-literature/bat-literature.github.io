            "itemType": "journalArticle",
            "title": "All You Can Eat: High Performance Capacity and Plasticity in the Common Big-Eared Bat, Micronycteris microtis (Chiroptera: Phyllostomidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sharlene E.",
                    "lastName": "Santana"
                },
                {
                    "creatorType": "author",
