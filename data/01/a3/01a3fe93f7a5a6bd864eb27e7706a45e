            "itemType": "journalArticle",
            "title": "Philippine bats of the genus Kerivoula (Chiroptera: Vespertilionidae): Overview and assessment of variation in K. pellucida and K. whiteheadi",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jodi L.",
                    "lastName": "Sedlock"
                },
                {
