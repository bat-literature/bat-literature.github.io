        "data": {
            "key": "X4TQQ5XD",
            "version": 58153,
            "itemType": "journalArticle",
            "title": "High similarity between a bat-serviced plant assemblage and that used by humans",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Annette Therese",
                    "lastName": "Scanlon"
                },
                {
                    "creatorType": "author",
