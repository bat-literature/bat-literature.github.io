            "title": "Cascading Effects of Birds and Bats in a Shaded Coffee Agroforestry System",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lauren",
                    "lastName": "Schmitt"
                },
                {
                    "creatorType": "author",
                    "firstName": "Russell",
                    "lastName": "Greenberg"
                },
                {
                    "creatorType": "author",
