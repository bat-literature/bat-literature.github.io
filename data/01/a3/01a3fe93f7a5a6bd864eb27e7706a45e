            "title": "Chapter 5: Enhanced Sampling of Bat Assemblages: A Field Test on Mount Banahaw, Luzon",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jodi L.",
                    "lastName": "Sedlock"
                },
