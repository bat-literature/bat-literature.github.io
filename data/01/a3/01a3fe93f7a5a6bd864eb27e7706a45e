            "itemType": "journalArticle",
            "title": "Synergistic effect of land-use and vegetation greenness on vulture nestling body condition in arid ecosystems",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Andrea",
                    "lastName": "Santangeli"
                },
                {
                    "creatorType": "author",
