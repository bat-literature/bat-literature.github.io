            "itemType": "journalArticle",
            "title": "Against all odds: Explaining high host specificity in dispersal-prone parasites",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Carl W.",
                    "lastName": "Dick"
                },
                {
                    "creatorType": "author",
                    "firstName": "Bruce D.",
                    "lastName": "Patterson"
