            "itemType": "journalArticle",
            "title": "The species–accumulation curve and estimation of species richness",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Karl I.",
                    "lastName": "Ugland"
                },
                {
                    "creatorType": "author",
