            "title": "Bee diversity along a disturbance gradient in tropical lowland forests of south‐east Asia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lee Hsiang",
                    "lastName": "Liow"
                },
                {
                    "creatorType": "author",
                    "firstName": "Navjot S.",
                    "lastName": "Sodhi"
