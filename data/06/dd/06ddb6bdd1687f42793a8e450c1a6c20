            "itemType": "journalArticle",
            "title": "Application of habitat thresholds in conservation: Considerations, limitations, and future directions",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Yntze",
                    "lastName": "Van Der Hoek"
                },
