        "data": {
            "key": "IQYGY2NZ",
            "version": 79408,
            "itemType": "journalArticle",
            "title": "HUMAN LAND USE INFLUENCES CHRONIC WASTING DISEASE PREVALENCE IN MULE DEER",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Matthew L.",
                    "lastName": "Farnsworth"
                },
                {
                    "creatorType": "author",
