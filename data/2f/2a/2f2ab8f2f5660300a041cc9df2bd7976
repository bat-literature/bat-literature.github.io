            "title": "Invasional meltdown: Invader–invader mutualism facilitates a secondary invasion",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Peter T",
                    "lastName": "Green"
                },
                {
                    "creatorType": "author",
                    "firstName": "Dennis J",
                    "lastName": "O'Dowd"
                },
                {
                    "creatorType": "author",
