            "title": "IMMUNE ACTIVITY IN TEMPERATE AND TROPICAL HOUSE SPARROWS: A COMMON-GARDEN EXPERIMENT",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Lynn B.",
                    "lastName": "Martin Ii"
                },
                {
                    "creatorType": "author",
