                    "lastName": "Paul"
                },
                {
                    "creatorType": "author",
                    "firstName": "DeeAnn",
                    "lastName": "Reeder"
                },
                {
                    "creatorType": "author",
                    "firstName": "Nancy B.",
                    "lastName": "Simmons"
                },
                {
