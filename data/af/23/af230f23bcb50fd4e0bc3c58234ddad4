            "itemType": "journalArticle",
            "title": "Researching little-known species: the African bat Otomops martiensseni (Chiroptera: Molossidae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "M B",
                    "lastName": "Fenton"
                },
                {
                    "creatorType": "author",
                    "firstName": "P J",
                    "lastName": "Taylor"
                },
                {
                    "creatorType": "author",
