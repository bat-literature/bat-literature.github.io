            "itemType": "journalArticle",
            "title": "Fruit diet of frugivorous bats (Cynopterus brachyotis and Cynopterus horsfieldii) in tropical hill forests of Peninsular Malaysia",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christine",
                    "lastName": "Fletcher"
                },
                {
                    "creatorType": "author",
