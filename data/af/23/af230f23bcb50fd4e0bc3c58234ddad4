            "itemType": "journalArticle",
            "title": "RELATIVE POLLINATION EFFECTIVENESS OF FLORAL VISITORS OF PITCAIRNIA ANGUSTIFOLIA (BROMELIACEAE)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "José J.",
                    "lastName": "Fumero‐Cabán"
                },
                {
                    "creatorType": "author",
                    "firstName": "Elvia J.",
                    "lastName": "Meléndez‐Ackerman"
