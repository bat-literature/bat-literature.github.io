        "data": {
            "key": "8K249UEN",
            "version": 56539,
            "itemType": "journalArticle",
            "title": "Diet of the Myotis sodalis (Indiana Bat) at an Urban/Rural Interface",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nicole M.",
                    "lastName": "Tuttle"
