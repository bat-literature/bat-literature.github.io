            "itemType": "journalArticle",
            "title": "Liberating Biodiversity Data From COVID-19 Lockdown: Toward a knowledge hub for mammal host-virus information",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Nathan",
                    "lastName": "Upham"
                },
