            "title": "Identifying Suspect Bat Reservoirs of Emerging Infections",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Daniel",
                    "lastName": "Crowley"
                },
                {
                    "creatorType": "author",
                    "firstName": "Daniel",
