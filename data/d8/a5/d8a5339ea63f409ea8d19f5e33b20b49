            "itemType": "journalArticle",
            "title": "RADIOGRAPHIC EVALUATION OF CARDIAC SIZE IN FLYING FOX SPECIES (PTEROPUS RODRICENSIS, P. HYPOMELANUS, AND P. VAMPYRUS)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Antonia",
                    "lastName": "Gardner"
                },
                {
                    "creatorType": "author",
                    "firstName": "Margret S.",
                    "lastName": "Thompson"
                },
