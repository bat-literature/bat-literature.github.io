            "itemType": "journalArticle",
            "title": "Susceptibility and Pathogenesis of Little Brown Bats (Myotis lucifugus) to Heterologous and Homologous Rabies Viruses",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "April D.",
                    "lastName": "Davis"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jodie A.",
                    "lastName": "Jarvis"
