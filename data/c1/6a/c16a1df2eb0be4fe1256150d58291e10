            "title": "A three-decade review of telemetry studies on vultures and condors",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pablo A. E.",
                    "lastName": "Alarcón"
                },
                {
                    "creatorType": "author",
                    "firstName": "Sergio A.",
                    "lastName": "Lambertucci"
