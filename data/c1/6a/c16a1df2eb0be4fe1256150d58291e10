            "itemType": "journalArticle",
            "title": "Diet, ecological role and potential ecosystem services of the fruit bat, Cynopterus brachyotis, in a tropical city",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Angela An Qi",
                    "lastName": "Chan"
                },
