        "data": {
            "key": "VTC3Y2KQ",
            "version": 74727,
            "itemType": "journalArticle",
            "title": "Dropping dead: causes and consequences of vulture population declines worldwide",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Darcy L.",
                    "lastName": "Ogada"
                },
                {
                    "creatorType": "author",
