            "itemType": "journalArticle",
            "title": "The effect of bat (Rousettus aegyptiacus) dispersal on seed germination in eastern Mediterranean habitats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "I.",
                    "lastName": "Izhaki"
                },
                {
                    "creatorType": "author",
