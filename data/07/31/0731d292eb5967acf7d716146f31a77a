            "itemType": "journalArticle",
            "title": "Old World fruitbat phylogeny: evidence for convergent evolution and an endemic African clade",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "L. J.",
                    "lastName": "Hollar"
                },
                {
                    "creatorType": "author",
                    "firstName": "M. S.",
                    "lastName": "Springer"
