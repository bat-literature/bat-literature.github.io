            "itemType": "journalArticle",
            "title": "Angiotensin-converting enzyme 2 (ACE2) proteins of different bat species confer variable susceptibility to SARS-CoV entry",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Yuxuan",
                    "lastName": "Hou"
                },
                {
                    "creatorType": "author",
