            "itemType": "journalArticle",
            "title": "Seeing the wood for the trees, irregular silviculture supports bat populations in conifer plantations",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Patrick",
                    "lastName": "Cook"
                },
                {
                    "creatorType": "author",
                    "firstName": "Daniel",
