        "data": {
            "key": "JEEGIQ3E",
            "version": 17652,
            "itemType": "journalArticle",
            "title": "Seasonal differences in day-roost selection by Northern long-eared bats (Myotis septentrionalis) in Louisiana and a meta-analytical comparison across North America",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Carlos J.",
                    "lastName": "Garcia"
                },
                {
                    "creatorType": "author",
                    "firstName": "David A.",
                    "lastName": "Ray"
                },
                {
                    "creatorType": "author",
