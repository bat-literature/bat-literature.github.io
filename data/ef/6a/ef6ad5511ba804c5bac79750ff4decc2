            "itemType": "journalArticle",
            "title": "Bat response to prescribed fire and overstory thinning in hardwood forest on the Cumberland Plateau, Tennessee",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Maxwell R.",
                    "lastName": "Cox"
                },
                {
                    "creatorType": "author",
