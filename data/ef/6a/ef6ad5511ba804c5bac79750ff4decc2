            "itemType": "journalArticle",
            "title": "Agricultural Fast Food: Bats Feeding in Banana Monocultures Are Heavier but Have Less Diverse Gut Microbiota",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Priscilla",
                    "lastName": "Alpízar"
                },
                {
                    "creatorType": "author",
