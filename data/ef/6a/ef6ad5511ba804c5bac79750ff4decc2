            "title": "Effects of turbine height and cut-in speed on bat and swallow fatalities at wind energy facilities",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Alexandra M.",
                    "lastName": "Anderson"
                },
                {
                    "creatorType": "author",
                    "firstName": "Catherine B.",
                    "lastName": "Jardine"
