            "itemType": "journalArticle",
            "title": "Foliage-roosting eastern red bats select for features associated with management in a central hardwood forest",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Elizabeth A.",
                    "lastName": "Beilke"
                },
                {
