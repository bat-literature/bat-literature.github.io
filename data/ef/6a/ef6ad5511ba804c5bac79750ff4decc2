            "title": "Chapter 2: Mammalian Diversity Patterns on Mount Palali, Caraballo Mountains, Luzon",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Phillip A.",
                    "lastName": "Alviola"
                },
                {
                    "creatorType": "author",
