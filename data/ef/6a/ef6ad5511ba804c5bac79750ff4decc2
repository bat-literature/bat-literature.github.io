            "title": "Habitat Associations of Overwintering Bats in Managed Pine Forest Landscapes",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Brett R.",
                    "lastName": "Andersen"
                },
                {
                    "creatorType": "author",
