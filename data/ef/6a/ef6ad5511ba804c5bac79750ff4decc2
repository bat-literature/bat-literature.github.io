            "title": "Environmental Seasonality Regulates Community Evenness in Neotropical Bat Communities",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Sergio",
                    "lastName": "Estrada-Villegas"
                },
                {
                    "creatorType": "author",
                    "firstName": "Jairo",
