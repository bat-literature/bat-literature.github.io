            "version": 73228,
            "itemType": "journalArticle",
            "title": "Nuclear localization and secretion competence are conserved among henipavirus matrix proteins",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Elisabeth C",
                    "lastName": "McLinton"
                },
                {
                    "creatorType": "author",
