            "itemType": "journalArticle",
            "title": "Molecular detection of adenoviruses, rhabdoviruses, and paramyxoviruses in bats from Kenya",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Christina",
                    "lastName": "Conrardy"
                },
                {
