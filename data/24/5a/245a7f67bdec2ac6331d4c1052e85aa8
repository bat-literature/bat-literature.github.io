            "itemType": "journalArticle",
            "title": "Vocal recognition in mexican free-tailed bats: do pups recognize mothers?",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Jonathan P.",
                    "lastName": "Balcombe"
                },
                {
