            "title": "The importance of natural habitats to Brazilian free-tailed bats in intensive agricultural landscapes in the Winter Garden region of Texas, United States",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Noa",
                    "lastName": "Davidai"
                },
                {
                    "creatorType": "author",
                    "firstName": "John K.",
                    "lastName": "Westbrook"
                },
