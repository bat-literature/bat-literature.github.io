        "data": {
            "key": "49KRQQ26",
            "version": 61269,
            "itemType": "journalArticle",
            "title": "Prey size is more representative than prey taxa when measuring dietary overlap in sympatric forest bats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Timothy J.",
                    "lastName": "Divoll"
                },
                {
                    "creatorType": "author",
                    "firstName": "Veronica A.",
