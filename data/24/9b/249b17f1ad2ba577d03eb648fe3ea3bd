            "title": "Understanding human – bat interactions in NSW, Australia: improving risk communication for prevention of Australian bat lyssavirus",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Emma K",
                    "lastName": "Quinn"
                },
                {
                    "creatorType": "author",
                    "firstName": "Peter D",
                    "lastName": "Massey"
                },
                {
                    "creatorType": "author",
