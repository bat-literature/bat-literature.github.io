            "title": "Molecular Systematics of the Fruit Bat, Artibeus jamaicensis: Origin of an Unusual Island Population",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D. E.",
                    "lastName": "Pumo"
                },
                {
                    "creatorType": "author",
