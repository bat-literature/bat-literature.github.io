            "itemType": "journalArticle",
            "title": "Pollination biology and reproduction of Seemannia sylvatica (Kunth) Hanstein (Gesneriaceae) in the Serra da Bodoquena National Park, Mato Grosso do Sul",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Eduardo",
                    "lastName": "Camargo"
                },
                {
                    "creatorType": "author",
                    "firstName": "Licléia Da Cruz",
                    "lastName": "Rodrigues"
                },
                {
