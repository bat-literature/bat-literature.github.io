            "itemType": "journalArticle",
            "title": "Effects of Vulture Declines on Facultative Scavengers and Potential Implications for Mammalian Disease Transmission",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D. L.",
                    "lastName": "Ogada"
                },
                {
                    "creatorType": "author",
                    "firstName": "M. E.",
