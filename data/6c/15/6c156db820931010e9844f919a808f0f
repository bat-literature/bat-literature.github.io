            "itemType": "journalArticle",
            "title": "Night and day service: Distyly and mixed pollination system in Faramea cyanea (Rubiaceae)",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Pietro Kiyoshi",
                    "lastName": "Maruyama"
                },
                {
                    "creatorType": "author",
