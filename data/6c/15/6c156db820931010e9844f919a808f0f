            "itemType": "journalArticle",
            "title": "Molecular divergence in tropical tree populations occupying environmental mosaics",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "D.",
                    "lastName": "Audigeos"
                },
                {
                    "creatorType": "author",
                    "firstName": "L.",
                    "lastName": "Brousseau"
                },
                {
                    "creatorType": "author",
                    "firstName": "S.",
                    "lastName": "Traissac"
                },
