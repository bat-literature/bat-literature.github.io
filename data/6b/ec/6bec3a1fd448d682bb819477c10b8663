            "version": 28998,
            "itemType": "journalArticle",
            "title": "Asymmetric Contribution of Isotopically Contrasting Food Sources to Vertebrate Consumers in a Subtropical Semi‐arid Ecosystem",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "L. Gerardo",
                    "lastName": "Herrera Montalvo"
                },
                {
                    "creatorType": "author",
                    "firstName": "Malinalli",
