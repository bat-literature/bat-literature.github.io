            "title": "Parasitization of bats by bat flies (Streblidae) in fragmented habitats",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Thomas",
                    "lastName": "Hiller"
                },
                {
                    "creatorType": "author",
                    "firstName": "Stefan Dominik",
                    "lastName": "Brändel"
                },
                {
                    "creatorType": "author",
                    "firstName": "Benjamin",
