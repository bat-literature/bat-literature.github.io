            "itemType": "journalArticle",
            "title": "Notes on Vampyressa thyone (Chiroptera: Phyllostomidae): distribution, genetics and hypopigmentation",
            "creators": [
                {
                    "creatorType": "author",
                    "firstName": "Giovani",
                    "lastName": "Hernández-Canchola"
                },
                {
                    "creatorType": "author",
